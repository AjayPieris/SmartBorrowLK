@model SmartBorrowLK.ViewModels.CreateReviewViewModel
@{ ViewData["Title"] = "Write a Review"; }

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="glass-panel p-4 p-md-5 fade-in-up">
                <div class="text-center mb-4">
                    <div class="mb-3" style="width: 56px; height: 56px; border-radius: 50%; background: var(--sb-warning-bg); display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                        <i class="bi bi-star-fill" style="color: var(--sb-warning); font-size: 1.4rem;"></i>
                    </div>
                    <h3 class="fw-bold mb-1">Review @Model.ItemName</h3>
                    <p style="color: var(--sb-text-muted); font-size: 0.9rem;">Your feedback helps keep the SmartBorrow LK community safe.</p>
                </div>

                <form asp-action="Create" method="post" id="reviewForm">
                    <input type="hidden" asp-for="ListingId" />
                    <input type="hidden" asp-for="ItemName" />

                    <div class="mb-3">
                        <label asp-for="Rating" class="form-label">Rating (1 to 5 Stars)</label>
                        <select asp-for="Rating" class="form-select">
                            <option value="5">⭐⭐⭐⭐⭐ - Excellent</option>
                            <option value="4">⭐⭐⭐⭐ - Good</option>
                            <option value="3">⭐⭐⭐ - Average</option>
                            <option value="2">⭐⭐ - Poor</option>
                            <option value="1">⭐ - Terrible</option>
                        </select>
                        <span asp-validation-for="Rating" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Comment" class="form-label">Your Experience</label>
                        <textarea asp-for="Comment" class="form-control" rows="4"
                                  placeholder="How was the equipment? Was the owner communicative?" style="resize: none;"></textarea>
                        <span asp-validation-for="Comment" class="text-danger small"></span>
                        <small class="d-block mt-2" style="color: var(--sb-text-dim); font-style: italic;">
                            Note: Our AI will review this comment for inappropriate language before publishing.
                        </small>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold" id="submitBtn">
                        <span id="btnText">Submit Review</span>
                        <span id="btnSpinner" class="spinner-border spinner-border-sm d-none ms-2" role="status" aria-hidden="true"></span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('reviewForm').addEventListener('submit', function() {
            document.getElementById('btnText').innerText = 'AI is analyzing your review...';
            document.getElementById('btnSpinner').classList.remove('d-none');
            document.getElementById('submitBtn').disabled = true;
        });
    </script>
}