@model SmartBorrowLK.Models.Listing
@{
    ViewData["Title"] = Model.Item?.Name ?? "Listing Details";
    var isLoggedIn = Context.Session.GetInt32("UserId") != null;
}

<div class="container py-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-4">
        <i class="bi bi-arrow-left"></i> Back to Marketplace
    </a>

    <div class="row g-4">
        <!-- Image Column -->
        <div class="col-lg-6">
            <div class="card sb-card overflow-hidden">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Item?.Name" class="img-fluid" style="max-height: 450px; object-fit: cover; width: 100%;" />
                }
                else if (!string.IsNullOrEmpty(Model.Item?.ImageUrl))
                {
                    <img src="@Model.Item.ImageUrl" alt="@Model.Item.Name" class="img-fluid" style="max-height: 450px; object-fit: cover; width: 100%;" />
                }
                else
                {
                    <div class="bg-dark d-flex align-items-center justify-content-center" style="height: 350px;">
                        <i class="bi bi-image display-1 text-muted"></i>
                    </div>
                }
            </div>
        </div>

        <!-- Details Column -->
        <div class="col-lg-6">
            <div class="card sb-card p-4">
                <span class="badge bg-success-subtle text-success mb-2 align-self-start">
                    <i class="bi bi-check-circle"></i> @Model.Status
                </span>
                <h2 class="fw-bold mb-1">@Model.Item?.Name</h2>
                <div class="d-flex gap-2 mb-3">
                    <span class="badge bg-secondary-subtle text-secondary">@Model.Item?.Condition</span>
                    <span class="badge bg-info-subtle text-info">Risk: @Model.RiskScore/100</span>
                </div>

                <div class="mb-3">
                    <span class="display-6 fw-bold text-accent">Rs. @Model.PricePerDay.ToString("N0")</span>
                    <span class="text-muted fs-6"> / day</span>
                </div>

                <h6 class="fw-semibold text-uppercase text-muted small mt-3 mb-2">Description</h6>
                <p>@Model.Description</p>

                <h6 class="fw-semibold text-uppercase text-muted small mt-3 mb-2">Rental Terms</h6>
                <p class="small">@Model.Terms</p>

                <h6 class="fw-semibold text-uppercase text-muted small mt-3 mb-2">Owner</h6>
                <p><i class="bi bi-person-circle"></i> @Model.Owner?.Name</p>

                <hr />

                @if (isLoggedIn && Model.Status == "Approved")
                {
                    <div class="d-flex gap-3">
                        <a asp-controller="Booking" asp-action="Book" asp-route-listingId="@Model.Id"
                           class="btn btn-accent flex-grow-1">
                            <i class="bi bi-calendar-plus"></i> Book Now
                        </a>
                        <a asp-controller="Review" asp-action="Create" asp-route-listingId="@Model.Id"
                           class="btn btn-outline-light flex-grow-1">
                            <i class="bi bi-star"></i> Write Review
                        </a>
                    </div>
                }
                else if (!isLoggedIn)
                {
                    <a asp-controller="Auth" asp-action="Login" class="btn btn-accent w-100">
                        <i class="bi bi-box-arrow-in-right"></i> Login to Book
                    </a>
                }
            </div>
        </div>
    </div>
</div>
