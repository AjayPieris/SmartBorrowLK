@model SmartBorrowLK.Models.Listing
@{
    ViewData["Title"] = Model.Item?.Name ?? "Listing Details";
    var isLoggedIn = User.Identity?.IsAuthenticated == true;
}

<div class="container py-5">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3 mb-4">
        <i class="bi bi-arrow-left me-1"></i> Back to Browse
    </a>

    <div class="row g-5 fade-in-up">
        <!-- Image Column -->
        <div class="col-lg-6">
            <div class="position-sticky" style="top: 100px;">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Item?.Name" class="detail-image" />
                }
                else if (!string.IsNullOrEmpty(Model.Item?.ImageUrl))
                {
                    <img src="@Model.Item.ImageUrl" alt="@Model.Item.Name" class="detail-image" />
                }
                else
                {
                    <div class="detail-image d-flex align-items-center justify-content-center" style="height: 400px; background: var(--sb-surface);">
                        <i class="bi bi-camera" style="font-size: 3rem; color: var(--sb-text-dim); opacity: 0.3;"></i>
                    </div>
                }
            </div>
        </div>

        <!-- Details Column -->
        <div class="col-lg-6">
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="badge" style="background: rgba(129,236,255,0.1); color: var(--sb-primary);">@Model.Item?.Condition</span>
                <div class="rating-badge">
                    <i class="bi bi-star-fill"></i> 4.9 (12 reviews)
                </div>
            </div>

            <h1 class="fw-bold mb-3" style="font-size: 2.2rem; letter-spacing: -0.02em;">@Model.Item?.Name</h1>

            <div class="d-flex align-items-end gap-2 mb-4 pb-4" style="border-bottom: 1px solid var(--sb-outline);">
                <span class="text-price" style="font-size: 2rem;">Rs. @Model.PricePerDay.ToString("N0")</span>
                <span class="pb-1" style="color: var(--sb-text-muted);">/ day</span>
            </div>

            <div class="mb-4">
                <h5 class="fw-bold mb-3">Description</h5>
                <p style="color: var(--sb-text-muted); line-height: 1.7;">@Model.Description</p>
            </div>

            <div class="mb-4">
                <h5 class="fw-bold mb-3">Rental Terms</h5>
                <div class="glass-panel p-3" style="color: var(--sb-text-muted); font-size: 0.9rem; line-height: 1.7;">
                    @Model.Terms
                </div>
            </div>

            <div class="d-flex align-items-center mb-4 p-3 glass-panel">
                <div class="profile-avatar me-3" style="width: 48px; height: 48px; font-size: 1.1rem; overflow: hidden;">
                    @if (!string.IsNullOrEmpty(Model.Owner?.ProfileImageUrl))
                    {
                        <img src="@Model.Owner.ProfileImageUrl" alt="@Model.Owner.Name" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
                    }
                    else
                    {
                        @(string.IsNullOrEmpty(Model.Owner?.Name) ? "O" : Model.Owner.Name.Substring(0, 1).ToUpper())
                    }
                </div>
                <div>
                    <h6 class="mb-0 fw-bold">Owned by @Model.Owner?.Name</h6>
                    <small style="color: var(--sb-text-muted);">Verified Vendor <i class="bi bi-patch-check-fill ms-1" style="color: var(--sb-primary);"></i></small>
                </div>
            </div>

            @if (isLoggedIn && Model.Status == "Approved")
            {
                <a asp-controller="Booking" asp-action="Book" asp-route-listingId="@Model.Id"
                   class="btn btn-primary btn-lg w-100 py-3 rounded-3 fw-bold" style="font-size: 1.1rem;">
                    <i class="bi bi-calendar-check me-2"></i>Book Now
                </a>
                
                @if (Model.OwnerId != int.Parse(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0"))
                {
                    <button type="button" class="btn btn-outline-secondary btn-lg w-100 py-3 mt-3 rounded-3 fw-bold open-chat-btn"
                            data-owner-id="@Model.OwnerId" 
                            data-owner-name="@Model.Owner?.Name"
                            style="font-size: 1.1rem;">
                        <i class="bi bi-chat-dots me-2"></i>Contact Seller
                    </button>
                }
            }
            else if (!isLoggedIn)
            {
                <a asp-controller="Auth" asp-action="Login"
                   class="btn btn-primary btn-lg w-100 py-3 rounded-3 fw-bold">
                    Log in to Book
                </a>
            }
            else if (Model.Status != "Approved")
            {
                <button class="btn btn-secondary btn-lg w-100 py-3 rounded-3 fw-bold" disabled>
                    Listing is @Model.Status
                </button>
            }
        </div>
    </div>
</div>
