@model IEnumerable<SmartBorrowLK.Models.Listing>
@{
    ViewData["Title"] = "Browse Listings";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--sb-secondary);">Explore Tech Gear</h2>
            <p class="text-muted mb-0">Discover top-tier equipment ready to rent today</p>
        </div>
        @if (Context.Session.GetString("UserRole") == "Vendor")
        {
            <a asp-action="Create" class="btn btn-accent rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> List Item
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-box-seam display-1 text-muted opacity-50 mb-3"></i>
            <h4 class="fw-semibold" style="color: var(--sb-secondary);">No listings yet</h4>
            <p class="text-muted mb-4">Check back later or be the first to list your gear!</p>
            @if (Context.Session.GetString("UserRole") == "Vendor")
            {
                <a asp-action="Create" class="btn btn-primary rounded-pill px-4">Start Listing</a>
            }
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var listing in Model)
            {
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <a asp-action="Details" asp-route-id="@listing.Id" class="text-decoration-none">
                        <div class="sb-listing-card">
                            @if (!string.IsNullOrEmpty(listing.Item?.ImageUrl))
                            {
                                <img src="@listing.Item.ImageUrl" class="card-img-top" alt="@listing.Item.Name" />
                            }
                            else
                            {
                                <div class="card-img-top bg-light d-flex align-items-center justify-content-center">
                                    <i class="bi bi-camera text-muted opacity-50" style="font-size: 3rem;"></i>
                                </div>
                            }
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="listing-title">@listing.Item?.Name</h5>
                                    <span class="rating-badge ms-2 flex-shrink-0">
                                        <i class="bi bi-star-fill"></i> 4.9
                                    </span>
                                </div>
                                <p class="listing-desc">
                                    @listing.Description
                                </p>
                                <div class="listing-price-row mt-3">
                                    <div>
                                        <span class="price-tag">Rs. @listing.PricePerDay.ToString("N0")</span>
                                        <span class="text-muted small">/ day</span>
                                    </div>
                                    <span class="btn btn-sm btn-outline-primary rounded-pill px-3">View</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>
