@model IEnumerable<SmartBorrowLK.Models.Listing>
@{
    ViewData["Title"] = "Browse Listings";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-grid"></i> Marketplace</h2>
            <p class="text-muted mb-0">Browse available tech gear for rent</p>
        </div>
        @if (Context.Session.GetString("UserRole") == "Vendor")
        {
            <a asp-action="Create" class="btn btn-accent">
                <i class="bi bi-plus-circle"></i> List Your Gear
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No listings available yet</h4>
            <p class="text-muted">Be the first to list your tech gear!</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var listing in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card sb-listing-card h-100">
                        @if (!string.IsNullOrEmpty(listing.Item?.ImageUrl))
                        {
                            <img src="@listing.Item.ImageUrl" class="card-img-top" alt="@listing.Item.Name"
                                 style="height: 220px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="card-img-top bg-dark d-flex align-items-center justify-content-center" style="height: 220px;">
                                <i class="bi bi-camera display-3 text-muted"></i>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-semibold mb-1">@listing.Item?.Name</h5>
                            <div class="d-flex gap-2 mb-2">
                                <span class="badge bg-secondary-subtle text-secondary">@listing.Item?.Condition</span>
                            </div>
                            <p class="card-text text-muted small flex-grow-1">
                                @if (!string.IsNullOrEmpty(listing.Description))
                                {
                                    @(listing.Description.Length > 100 ? listing.Description.Substring(0, 100) + "..." : listing.Description)
                                }
                            </p>
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <div>
                                    <span class="fw-bold text-accent fs-5">Rs. @listing.PricePerDay.ToString("N0")</span>
                                    <small class="text-muted"> / day</small>
                                </div>
                                <a asp-action="Details" asp-route-id="@listing.Id" class="btn btn-sm btn-outline-light">
                                    View Details <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-top-0 small text-muted px-3 pb-3">
                            <i class="bi bi-person"></i> @listing.Owner?.Name
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
