@model IEnumerable<SmartBorrowLK.Models.Listing>

@{
    ViewData["Title"] = "Listings";
}

<h1>Listings</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Listing</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Price</th>
            <th>Category</th>
            <th>Location</th>
            <th>Condition</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Title)</td>
            <td>@item.Description?.Substring(0, Math.Min(item.Description.Length, 50))...</td>
            <td>@Html.DisplayFor(modelItem => item.Price)</td>
            <td>@Html.DisplayFor(modelItem => item.Category)</td>
            <td>@Html.DisplayFor(modelItem => item.Location)</td>
            <td>@Html.DisplayFor(modelItem => item.Condition)</td>
            <td>@Html.DisplayFor(modelItem => item.Status)</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
            </td>
        </tr>
}
    </tbody>
</table>
