@model IEnumerable<SmartBorrowLK.Models.Listing>
@{
    ViewData["Title"] = "Browse Listings";
    var isLoggedIn = User.Identity?.IsAuthenticated == true;
}

<div class="container py-5">
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-end mb-5 gap-3 fade-in-up">
        <div>
            <div class="hero-tag" style="margin-bottom: 1rem;">
                <span class="dot"></span>
                Marketplace
            </div>
            <h1 class="fw-bold mb-2" style="font-size: 2.5rem; letter-spacing: -0.02em;">Browse Tech Gear</h1>
            <p style="color: var(--sb-text-muted); font-size: 1.05rem; margin-bottom: 0;">
                Discover premium equipment available for rent in Sri Lanka.
            </p>
        </div>
        @if (isLoggedIn)
        {
            <a asp-action="Create" class="btn btn-primary px-4 py-2 rounded-3 fw-bold">
                <i class="bi bi-plus-circle me-2"></i>List Your Gear
            </a>
        }
    </div>

    <!-- Listings Grid -->
    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var listing in Model)
            {
                <div class="col-sm-6 col-lg-4 col-xl-3 fade-in-up">
                    <a asp-action="Details" asp-route-id="@listing.Id" class="text-decoration-none">
                        <div class="listing-card">
                            <div style="overflow: hidden;">
                                @if (!string.IsNullOrEmpty(listing.ImageUrl))
                                {
                                    <img src="@listing.ImageUrl" alt="@listing.Item?.Name" class="listing-card-img" />
                                }
                                else if (!string.IsNullOrEmpty(listing.Item?.ImageUrl))
                                {
                                    <img src="@listing.Item.ImageUrl" alt="@listing.Item?.Name" class="listing-card-img" />
                                }
                                else
                                {
                                    <div class="listing-img-placeholder">
                                        <i class="bi bi-camera"></i>
                                    </div>
                                }
                            </div>
                            <div class="listing-card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="listing-card-title mb-0" style="color: var(--sb-text);">@listing.Item?.Name</h6>
                                </div>
                                @if (!string.IsNullOrEmpty(listing.Item?.Condition))
                                {
                                    <span class="badge mb-2" style="background: rgba(129,236,255,0.1); color: var(--sb-primary); font-size: 0.68rem;">
                                        @listing.Item.Condition
                                    </span>
                                }
                                <div class="listing-card-price mt-auto">
                                    Rs. @listing.PricePerDay.ToString("N0") <span>/ day</span>
                                </div>
                                <div class="listing-card-meta">
                                    <i class="bi bi-person-circle"></i>
                                    <span>@listing.Owner?.Name</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state fade-in-up">
            <i class="bi bi-box-seam" style="font-size: 3.5rem;"></i>
            <h4 class="fw-bold mt-3 mb-2">No listings available yet</h4>
            <p style="color: var(--sb-text-muted);">Be the first to list your tech gear on SmartBorrowLK!</p>
            @if (isLoggedIn)
            {
                <a asp-action="Create" class="btn btn-primary px-4 py-2 rounded-3 mt-2">
                    <i class="bi bi-plus-circle me-2"></i>Create a Listing
                </a>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Register" class="btn btn-primary px-4 py-2 rounded-3 mt-2">
                    Get Started
                </a>
            }
        </div>
    }
</div>