@model SmartBorrowLK.ViewModels.CreateListingViewModel
@{
    ViewData["Title"] = "List Your Gear";
}

<div class="container py-5">
    <!-- Header -->
    <div class="text-center mb-5 fade-in-up">
        <div class="hero-tag mx-auto" style="margin-bottom: 1.5rem;">
            <span class="material-symbols-outlined" style="font-size: 14px; font-variation-settings: 'FILL' 1;">auto_awesome</span>
            AI-Powered Listing
        </div>
        <h1 class="fw-bold mb-3" style="font-size: 2.5rem; letter-spacing: -0.02em;">
            Turn Your Gear Into
            <span style="background: var(--sb-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Capital</span>
        </h1>
        <p style="color: var(--sb-text-muted); font-size: 1.05rem; max-width: 560px; margin: 0 auto;">
            Upload a photo and let our AI handle the technical specs, pricing, and description for your rental listing.
        </p>
    </div>

    <!-- Form Card -->
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <form asp-action="Create" method="post" enctype="multipart/form-data"
                  class="glass-panel p-4 p-md-5 fade-in-up delay-1">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                <div class="row g-4">
                    <!-- Left: Image Upload -->
                    <div class="col-md-5">
                        <div class="dropzone" onclick="document.getElementById('Image').click()">
                            <input type="file" asp-for="Image" id="Image" class="d-none" accept="image/*"
                                   onchange="previewImage(event)" />
                            <img id="imagePreview" alt="Preview"
                                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuDWrsF17u98F-L0_-tjc0GUB7mbLuFz8PWcXgqDKht8fMEZC5nwsVLcnJ6wqFprI--Ba7by7bsezBqMLTFbXn_QfCbT6ZsGYrxz_JtCExNugff5KiWu3JRlJZSA4DgJHWvD2d_4PoxoE7ZDHFqnhOIuMjCO9vVVHtqoTD4VTmZJORBNcAO7v5YLplxckZwx8s036WCZi_4lMvWWo_Xn1mX8ujB4WYvR0C5kBZfUdt57d5-2y5rjIbuXBiJ2ZmlyRsiqYKv9bTMWUFs"
                                 style="opacity: 0.35;" />
                            <div id="uploadPrompt" class="position-relative text-center p-4" style="z-index: 2;">
                                <div class="mb-3" style="width: 56px; height: 56px; border-radius: 50%; background: var(--sb-surface-high); display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                                    <span class="material-symbols-outlined" style="color: var(--sb-primary); font-size: 1.6rem;">add_a_photo</span>
                                </div>
                                <span class="fw-bold d-block" style="font-size: 1rem;">Drop your gear image</span>
                                <span class="small" style="color: var(--sb-text-muted);">AI will analyze brand and model</span>
                            </div>
                        </div>
                        <span asp-validation-for="Image" class="text-danger small d-block mt-1"></span>

                        <!-- Market Insights -->
                        <div class="glass-panel p-3 mt-3">
                            <h6 class="mb-3 d-flex align-items-center gap-2" style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--sb-primary-dim);">
                                <span class="material-symbols-outlined" style="font-size: 14px;">insights</span>
                                Live Market Insights
                            </h6>
                            <div class="d-flex justify-content-between align-items-end">
                                <div>
                                    <p class="mb-1 small" style="color: var(--sb-text-muted);">Average daily rate</p>
                                    <p class="mb-0 fw-bold" style="font-size: 1.6rem;">.00</p>
                                </div>
                                <div class="text-end">
                                    <p class="mb-1 small fw-bold" style="color: var(--sb-accent-light);">+12% Demand</p>
                                    <div class="risk-bar-bg" style="width: 80px;">
                                        <div class="risk-bar-fill" style="width: 75%; background: var(--sb-primary); box-shadow: 0 0 8px rgba(129,236,255,0.5);"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Form Fields -->
                    <div class="col-md-7">
                        <div class="mb-3">
                            <label asp-for="ItemName" class="form-label">Item Name</label>
                            <input asp-for="ItemName" class="form-control" placeholder="e.g. Sony Alpha a7R IV" type="text" />
                            <span asp-validation-for="ItemName" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-sm-6">
                                <label asp-for="Condition" class="form-label">Condition</label>
                                <select asp-for="Condition" class="form-select">
                                    <option value="Brand New">Brand New</option>
                                    <option value="Excellent">Excellent</option>
                                    <option value="Good">Good</option>
                                    <option value="Well Used">Well Used</option>
                                </select>
                                <span asp-validation-for="Condition" class="text-danger small d-block mt-1"></span>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="ManualPrice" class="form-label">Price / Day (LKR)</label>
                                <input asp-for="ManualPrice" class="form-control" placeholder="0.00" type="number" step="0.01" />
                                <span asp-validation-for="ManualPrice" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="RawDescription" class="form-label">Short Description</label>
                            <textarea asp-for="RawDescription" class="form-control" placeholder="Describe the key features and inclusions..." rows="4" style="resize: none;"></textarea>
                            <span asp-validation-for="RawDescription" class="text-danger small d-block mt-1"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold d-flex align-items-center justify-content-center gap-2" style="font-size: 1rem;">
                            <span class="material-symbols-outlined" style="font-size: 1.2rem; font-variation-settings: 'FILL' 1;">auto_fix_high</span>
                            Generate Listing
                        </button>
                        <p class="text-center mt-3 small" style="color: var(--sb-text-dim); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em;">
                            Our neural network will optimize your post for 30% higher conversion
                        </p>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(event) {
            var input = event.target;
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    var preview = document.getElementById('imagePreview');
                    preview.src = e.target.result;
                    preview.style.opacity = '1';
                    document.getElementById('uploadPrompt').style.display = 'none';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
