@{
    Layout = null;
    var userName = User.Identity?.Name;
    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
    var userEmail = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value ??
    (userName != null ? $"{userName.Replace(" ", "").ToLower()}@example.com" : "");
    var userProfileImage = User.Claims.FirstOrDefault(c => c.Type == "ProfileImage")?.Value;
    var isLoggedIn = User.Identity?.IsAuthenticated == true;
    var isAdmin = userRole?.Equals("Admin", StringComparison.OrdinalIgnoreCase) == true;
    var isVendor = userRole?.Equals("Vendor", StringComparison.OrdinalIgnoreCase) == true;
    
    string GetInitials(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "U";
        var parts = name.Split(' ');
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0].Substring(0, 1) + parts[1].Substring(0, 1)).ToUpper();
    }
}
<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>SmartBorrowLK | Rent Smart. Earn Easy.</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "on-primary-fixed-variant": "#005762",
              "tertiary-fixed": "#b8a3ff",
              "primary": "#81ecff",
              "secondary": "#929bfa",
              "secondary-fixed-dim": "#babfff",
              "primary-fixed-dim": "#00d4ec",
              "on-surface-variant": "#a7abb7",
              "tertiary-container": "#7c4dff",
              "background": "#0a0e17",
              "surface-container": "#151925",
              "surface-bright": "#262c3a",
              "surface-dim": "#0a0e17",
              "inverse-primary": "#006976",
              "surface-container-high": "#1a1f2c",
              "surface-container-highest": "#202633",
              "error": "#ff716c",
              "error-container": "#9f0519",
              "on-error-container": "#ffa8a3"
            },
            fontFamily: {
              "headline": ["Space Grotesk", "sans-serif"],
              "body": ["Inter", "sans-serif"]
            }
          },
        },
      }
    </script>
    <style>
        body { background-color: #0a0e17; color: #ebedfb; font-family: 'Inter', sans-serif; overflow-x: hidden; }
        .glass-panel { background: rgba(32, 38, 51, 0.4); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
        .hero-gradient { background: radial-gradient(circle at 50% 50%, rgba(129, 236, 255, 0.08) 0%, rgba(10, 14, 23, 0) 70%); }
    </style>
</head>
<body class="dark bg-background text-on-background selection:bg-primary/30">
<nav class="fixed top-0 w-full z-50 bg-slate-950/40 backdrop-blur-xl border-b border-white/10 shadow-[0_8px_32px_0_rgba(0,0,0,0.36)]">
    <div class="flex justify-between items-center w-full px-6 py-4 max-w-7xl mx-auto">
        <div class="text-2xl font-bold bg-gradient-to-br from-cyan-400 to-cyan-600 bg-clip-text text-transparent font-headline tracking-tight">
            SmartBorrowLK
        </div>
        <div class="hidden md:flex items-center space-x-8 font-headline tracking-tight">
            <a class="text-cyan-400 font-bold border-b-2 border-cyan-400 pb-1" asp-controller="Listing" asp-action="Index">Explore</a>
            <a class="text-slate-400 hover:text-slate-100 transition-colors hover:bg-white/5 px-3 py-1 rounded-lg" href="#how-it-works">How it Works</a>
        </div>
        <div class="flex items-center gap-4">
            @if (isLoggedIn)
            {
                <div class="relative group">
                    <button class="flex items-center gap-2 bg-white/5 hover:bg-white/10 p-1 pr-3 rounded-full transition-all border border-white/10">
                        <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold overflow-hidden border border-primary/30">
                            @if (!string.IsNullOrEmpty(userProfileImage))
                            {
                                <img src="@userProfileImage" alt="@userName" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <span>@GetInitials(userName)</span>
                            }
                        </div>
                        <span class="text-sm font-medium text-slate-200">@userName</span>
                    </button>
                    <div class="absolute right-0 top-full mt-2 w-56 rounded-xl bg-surface-container-high border border-white/10 shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-right z-50">
                        <div class="p-4 border-b border-white/10">
                            <p class="text-sm font-bold text-white truncate">@userName</p>
                            <p class="text-xs text-slate-400 truncate mt-1">@userEmail</p>
                        </div>
                        <div class="p-2 space-y-1">
                            @if (isAdmin)
                            {
                                <a asp-controller="Admin" asp-action="Dashboard" class="block px-3 py-2 text-sm text-slate-300 hover:text-white hover:bg-white/5 rounded-lg transition-colors">Admin Dashboard</a>
                            }
                            @if (isVendor)
                            {
                                <a asp-controller="Listing" asp-action="MyListings" class="block px-3 py-2 text-sm text-slate-300 hover:text-white hover:bg-white/5 rounded-lg transition-colors">My Listings</a>
                                <a asp-controller="Booking" asp-action="Requests" class="block px-3 py-2 text-sm text-slate-300 hover:text-white hover:bg-white/5 rounded-lg transition-colors">Booking Requests</a>
                            }
                            <a asp-controller="Booking" asp-action="MyBookings" class="block px-3 py-2 text-sm text-slate-300 hover:text-white hover:bg-white/5 rounded-lg transition-colors">My Bookings</a>
                        </div>
                        <div class="p-2 border-t border-white/10">
                            <a asp-controller="Auth" asp-action="Logout" class="block px-3 py-2 text-sm text-error hover:text-error-dim hover:bg-error/10 rounded-lg transition-colors">Logout</a>
                        </div>
                    </div>
                    <!-- invisible hit box for smooth dropdown interaction -->
                    <div class="absolute right-0 top-full w-full h-4"></div>
                </div>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Login" class="text-slate-300 hover:text-white flex items-center font-bold px-4 transition-colors">Login</a>
                <a asp-controller="Auth" asp-action="Register" class="bg-gradient-to-br from-primary to-primary-fixed-dim text-on-primary-fixed-variant font-bold px-6 py-2 rounded-xl hover:scale-105 transition-transform">Get Started</a>
            }
        </div>
    </div>
</nav>

