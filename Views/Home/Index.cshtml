@{
    ViewData["Title"] = "Home";
    var isLoggedIn = User.Identity?.IsAuthenticated == true;
    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
    var isVendor = userRole?.Equals("Vendor", StringComparison.OrdinalIgnoreCase) == true;
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="hero-gradient-bg"></div>
    <div class="hero-glow hero-glow-1"></div>
    <div class="hero-glow hero-glow-2"></div>

    <div class="container position-relative" style="z-index: 2;">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 fade-in-up">
                <div class="hero-tag">
                    <span class="dot"></span>
                    The Future of Access
                </div>
                <h1 class="hero-title">
                    Rent <span class="gradient-text">Smart.</span><br/>
                    Earn <span class="accent-text">Easy.</span>
                </h1>
                <p class="hero-desc mb-4">
                    Experience Sri Lanka's first AI-powered tech rental ecosystem. Securely borrow elite hardware or monetize your idle gear.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Listing" asp-action="Index"
                       class="btn btn-primary btn-lg px-4 py-3 rounded-3 fw-bold">
                        <i class="bi bi-search me-2"></i>Browse Items
                    </a>
                    @if (isLoggedIn && isVendor)
                    {
                        <a asp-controller="Listing" asp-action="Create"
                           class="btn btn-outline-primary btn-lg px-4 py-3 rounded-3 fw-bold">
                            <i class="bi bi-plus-circle me-2"></i>List Your Item
                        </a>
                    }
                    else if (!isLoggedIn)
                    {
                        <a asp-controller="Auth" asp-action="Register"
                           class="btn btn-outline-primary btn-lg px-4 py-3 rounded-3 fw-bold">
                            Become a Vendor
                        </a>
                    }
                </div>
            </div>
            <div class="col-lg-6 fade-in-up delay-2">
                <div class="hero-image-card">
                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAUqeSAF2DV2lbL6_RUAy9dYdRgYLKmm2MbtilfbJW8mYuEQpedsa2L44riRXqSyDBZd_onF-YhioQUjzx2QDQ9qwCRjhFXsorr3t_z3fLpTRvqpYcf8c-2LVhS86Imj9W0zOCgrWy14xYF9jRiC5Jbwz6Q1lmnEbnDPtsfBHn6LHt2tj5kU0_MwAt35lFolLUdpr9aGbjE2u5TvhLjmtKNLEdXNvP2I6uAZ0QSGrhFdjY3CNtybVt58ScEmQYB41lwXoJO5nqwOKM"
                         alt="Futuristic Drone" />
                    <div class="hero-card-overlay">
                        <div class="d-flex justify-content-between align-items-end">
                            <div>
                                <p class="mb-1 small fw-medium" style="color: var(--sb-text-muted); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.7rem;">Active Listing</p>
                                <h5 class="mb-0 fw-bold">DJI Mavic 3 Pro</h5>
                            </div>
                            <div class="text-end">
                                <span class="text-price fs-5">$45</span>
                                <span class="small" style="color: var(--sb-text-muted);">/day</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="py-5" style="background: rgba(15, 19, 29, 0.3);">
    <div class="container py-5">
        <div class="text-center mb-5 fade-in-up">
            <h2 class="fw-bold mb-3" style="font-size: 2.5rem;">Seamless Ecosystem</h2>
            <p style="color: var(--sb-text-muted); max-width: 600px; margin: 0 auto; font-size: 1.1rem;">
                Our proprietary tech-stack manages the complexity, so you can focus on the creativity.
            </p>
        </div>
        <div class="row g-4">
            <div class="col-md-4 fade-in-up delay-1">
                <div class="glass-panel p-4 h-100" style="border-top: 2px solid rgba(129, 236, 255, 0.15);">
                    <div class="mb-3" style="width: 48px; height: 48px; border-radius: 12px; background: rgba(129, 236, 255, 0.1); display: flex; align-items: center; justify-content: center;">
                        <span class="material-symbols-outlined" style="color: var(--sb-primary); font-variation-settings: 'FILL' 1;">auto_awesome</span>
                    </div>
                    <h4 class="fw-bold mb-3">AI Auto-Listings</h4>
                    <p style="color: var(--sb-text-muted); line-height: 1.7;">Simply upload a photo. Our neural vision engine generates optimized specs, pricing, and descriptions instantly.</p>
                </div>
            </div>
            <div class="col-md-4 fade-in-up delay-2">
                <div class="glass-panel p-4 h-100" style="border-top: 2px solid rgba(166, 140, 255, 0.15);">
                    <div class="mb-3" style="width: 48px; height: 48px; border-radius: 12px; background: rgba(166, 140, 255, 0.1); display: flex; align-items: center; justify-content: center;">
                        <span class="material-symbols-outlined" style="color: var(--sb-accent-light); font-variation-settings: 'FILL' 1;">shield_with_heart</span>
                    </div>
                    <h4 class="fw-bold mb-3">Smart Risk Scoring</h4>
                    <p style="color: var(--sb-text-muted); line-height: 1.7;">Integrated trust metrics ensure your gear is only handled by verified, high-rated professionals within our network.</p>
                </div>
            </div>
            <div class="col-md-4 fade-in-up delay-3">
                <div class="glass-panel p-4 h-100" style="border-top: 2px solid rgba(146, 155, 250, 0.15);">
                    <div class="mb-3" style="width: 48px; height: 48px; border-radius: 12px; background: rgba(146, 155, 250, 0.1); display: flex; align-items: center; justify-content: center;">
                        <span class="material-symbols-outlined" style="color: var(--sb-secondary); font-variation-settings: 'FILL' 1;">bolt</span>
                    </div>
                    <h4 class="fw-bold mb-3">Easy Booking</h4>
                    <p style="color: var(--sb-text-muted); line-height: 1.7;">One-tap rentals with integrated insurance and real-time delivery tracking for a frictionless experience.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Bento Grid -->
<section class="py-5">
    <div class="container py-5">
        <div class="bento-grid">
            <div class="bento-item bento-large">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuB-gu-HcMc87A_Jp0q22Vc8LkVqUunfD1jx3rh__t8I_-z8Q23Lc0NOb89NBQdUGhMYljiIC0GNOB1caOzeWXABZBvurWa8VPf1ebZj13O5LgnTsz2N0oBdN-v5uZsclCGrVdvTpB_jGTuu0I8q0SpTKZwiZa3pLNtF4rYclfhfdofM7b6JKeaH6I9XrUOnrQPtMhTtD_unHLd0i2z3dpIuWO56CFX3tio6eilYc3ENWyd9wmLVrUMVUezpoz40btyngWmeHmHXwBY" alt="MacBook Pro" />
                <div class="bento-overlay"></div>
                <div class="bento-content">
                    <span class="badge" style="background: rgba(129,236,255,0.15); color: var(--sb-primary); margin-bottom: 0.5rem;">MOST WANTED</span>
                    <h3 class="fw-bold mb-0" style="font-size: 1.6rem;">MacBook Pro M3 Max</h3>
                </div>
            </div>
            <div class="bento-item" style="grid-column: span 2;">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDkZLm48b2zIOHIIgWaP6ayES1ELk8q82U5-5gvYmSec2IHej4aNU9Bpm_hHypDFjm_ejSprsKzeEHteaKVN2jv0lzPZkmt9-Cdq6zAPp5yP2bd9EW_nUaFhEbQgE92KT5QuWC0PXuK0DixjtYIc5-fVSRghIQUM7W4Wu1fIXQFdZAWbSMMccZztM2zTgcwyiLYYOr4FFzZ71Um2hwL-ulpKFwgM9fTYVCd69c0rtPhEFyt-gwAQm8PKllanZLU0xbIs6G3Bv5c28c" alt="RED V-Raptor" />
                <div class="bento-overlay"></div>
                <div class="bento-content">
                    <h4 class="fw-bold mb-0">RED V-Raptor 8K</h4>
                </div>
            </div>
            <div class="bento-item bento-stat" style="background: rgba(124, 77, 255, 0.08);">
                <div class="text-center">
                    <p class="bento-stat-value mb-0" style="color: var(--sb-accent);">2.4k+</p>
                    <p class="bento-stat-label mb-0">Active Tech Units</p>
                </div>
            </div>
            <div class="bento-item bento-stat" style="background: rgba(129, 236, 255, 0.06);">
                <div class="text-center">
                    <p class="bento-stat-value mb-0" style="color: var(--sb-primary);">99%</p>
                    <p class="bento-stat-label mb-0">Trust Score</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5">
    <div class="container py-5">
        <div class="glass-panel text-center p-5 position-relative overflow-hidden" style="border-radius: 2rem;">
            <div class="position-absolute" style="top: -60px; right: -60px; width: 300px; height: 300px; background: rgba(129,236,255,0.06); border-radius: 50%; filter: blur(80px);"></div>
            <div class="position-absolute" style="bottom: -60px; left: -60px; width: 250px; height: 250px; background: rgba(124,77,255,0.06); border-radius: 50%; filter: blur(80px);"></div>
            <div class="position-relative" style="z-index: 2;">
                <h2 class="fw-bold mb-4" style="font-size: 2.2rem; max-width: 600px; margin: 0 auto;">
                    Ready to transform your unused tech into cash?
                </h2>
                <p class="mb-4" style="color: var(--sb-text-muted); font-size: 1.1rem; max-width: 500px; margin: 0 auto;">
                    Join 15,000+ tech enthusiasts who are already powering the rental economy.
                </p>
                <a asp-controller="Auth" asp-action="Register" class="btn btn-primary btn-lg px-5 py-3 rounded-3 fw-bold">
                    Create an Account
                </a>
            </div>
        </div>
    </div>
</section>