@{
    ViewData["Title"] = "Home";
    var isLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString("UserName"));
}

<!-- Hero Section -->
<section class="sb-hero">
    <div class="container">
        <div class="row align-items-center min-vh-75">
            <div class="col-lg-7">
                <span class="badge bg-accent-subtle text-accent mb-3 px-3 py-2 rounded-pill">
                    <i class="bi bi-stars"></i> AI-Powered Marketplace
                </span>
                <h1 class="display-3 fw-bold mb-3">
                    Rent Premium Tech<br />
                    <span class="text-gradient">Across Sri Lanka</span>
                </h1>
                <p class="lead text-light-muted mb-4" style="max-width: 540px;">
                    Cameras, drones, laptops, microphones — rent what you need, when you need it. 
                    AI-powered pricing, fraud detection, and smart reviews keep everyone safe.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a asp-controller="Listing" asp-action="Index" class="btn btn-accent btn-lg px-4">
                        <i class="bi bi-search"></i> Browse Gear
                    </a>
                    @if (!isLoggedIn)
                    {
                        <a asp-controller="Auth" asp-action="Register" class="btn btn-outline-light btn-lg px-4">
                            <i class="bi bi-person-plus"></i> Start Renting
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Listing" asp-action="Create" class="btn btn-outline-light btn-lg px-4">
                            <i class="bi bi-plus-circle"></i> List Your Gear
                        </a>
                    }
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block text-center">
                <div class="hero-visual">
                    <i class="bi bi-camera-reels display-1 text-accent"></i>
                    <i class="bi bi-laptop display-2 text-info ms-3"></i>
                    <i class="bi bi-mic display-2 text-warning ms-3"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">How It Works</h2>
            <p class="text-muted">Three simple steps to rent or list tech gear</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card sb-feature-card h-100 text-center">
                    <div class="card-body p-4">
                        <div class="feature-icon bg-primary-subtle rounded-circle mx-auto mb-3">
                            <i class="bi bi-pencil-square display-6 text-primary"></i>
                        </div>
                        <h5 class="fw-semibold">Describe Your Item</h5>
                        <p class="text-muted small">Type a simple description. Our AI generates professional listings with pricing and rental terms automatically.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card sb-feature-card h-100 text-center">
                    <div class="card-body p-4">
                        <div class="feature-icon bg-success-subtle rounded-circle mx-auto mb-3">
                            <i class="bi bi-shield-check display-6 text-success"></i>
                        </div>
                        <h5 class="fw-semibold">AI Risk Screening</h5>
                        <p class="text-muted small">Every listing gets an AI risk score. Admins review flagged items before they go live, keeping the marketplace safe.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card sb-feature-card h-100 text-center">
                    <div class="card-body p-4">
                        <div class="feature-icon bg-warning-subtle rounded-circle mx-auto mb-3">
                            <i class="bi bi-calendar-check display-6 text-warning"></i>
                        </div>
                        <h5 class="fw-semibold">Book & Review</h5>
                        <p class="text-muted small">Check availability, book instantly, and leave AI-analyzed reviews with trust scores after your rental.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="py-5 sb-stats-section">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-6 col-md-3">
                <h3 class="fw-bold text-accent mb-1">AI-Powered</h3>
                <small class="text-muted">Gemini AI Integration</small>
            </div>
            <div class="col-6 col-md-3">
                <h3 class="fw-bold text-accent mb-1">Secure</h3>
                <small class="text-muted">Risk Detection Built-in</small>
            </div>
            <div class="col-6 col-md-3">
                <h3 class="fw-bold text-accent mb-1">LKR</h3>
                <small class="text-muted">Local Currency Pricing</small>
            </div>
            <div class="col-6 col-md-3">
                <h3 class="fw-bold text-accent mb-1">Cloud</h3>
                <small class="text-muted">Cloudinary Image Hosting</small>
            </div>
        </div>
    </div>
</section>
