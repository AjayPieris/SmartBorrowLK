@model SmartBorrowLK.ViewModels.AdminDashboardViewModel
@{ ViewData["Title"] = "Admin Dashboard"; }

<div class="container mt-4">
    <h2 class="mb-4">Platform Overview</h2>

    <div class="row mb-5 text-center">
        <div class="col-md-3">
            <div class="card text-white bg-primary shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Total Listings</h5>
                    <h2>@Model.TotalListings</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-dark bg-warning shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Pending Review</h5>
                    <h2>@Model.PendingListingsCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Approved</h5>
                    <h2>@Model.ApprovedListingsCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-danger shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">High Risk (>70)</h5>
                    <h2>@Model.HighRiskCount</h2>
                </div>
            </div>
        </div>
    </div>

    <h3 class="mb-3">Action Required: Pending Listings</h3>
    
    @if (!Model.PendingListings.Any())
    {
        <div class="alert alert-success">All caught up! There are no listings waiting for review.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Item</th>
                        <th>Vendor</th>
                        <th>AI Price/Day</th>
                        <th>AI Risk Score</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var listing in Model.PendingListings)
                    {
                        <tr>
                            <td>
                                <img src="@listing.Item.ImageUrl" alt="@listing.Item.Name" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px; margin-right: 10px;" />
                                <strong>@listing.Item.Name</strong>
                                <br />
                                <small class="text-muted">@listing.Description.Substring(0, Math.Min(50, listing.Description.Length))...</small>
                            </td>
                            <td>@listing.Owner.Name</td>
                            <td>Rs. @listing.PricePerDay.ToString("N0")</td>
                            <td>
                                <span class="badge @(listing.RiskScore > 70 ? "bg-danger" : listing.RiskScore > 40 ? "bg-warning" : "bg-success")">
                                    @listing.RiskScore / 100
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <form asp-action="Approve" asp-route-id="@listing.Id" method="post">
                                        <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                    </form>
                                    <form asp-action="Reject" asp-route-id="@listing.Id" method="post">
                                        <button type="submit" class="btn btn-sm btn-danger">Reject</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>