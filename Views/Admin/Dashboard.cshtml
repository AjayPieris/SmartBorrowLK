@model SmartBorrowLK.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="admin-wrapper">
    <!-- Sidebar -->
    <aside class="admin-sidebar d-none d-lg-flex">
        <div class="sidebar-title">Admin Central</div>
        <div class="sidebar-subtitle">AI-Risk Verified</div>
        <nav>
            <a class="sidebar-link active" href="#">
                <span class="material-symbols-outlined" style="font-size: 1.2rem;">dashboard</span>
                Dashboard
            </a>
            <a class="sidebar-link" asp-controller="Listing" asp-action="Index">
                <span class="material-symbols-outlined" style="font-size: 1.2rem;">list_alt</span>
                Listings
            </a>
            <a class="sidebar-link" href="#">
                <span class="material-symbols-outlined" style="font-size: 1.2rem;">group</span>
                Users
            </a>
            <a class="sidebar-link" href="#">
                <span class="material-symbols-outlined" style="font-size: 1.2rem;">settings</span>
                Settings
            </a>
        </nav>
        <div class="mt-auto">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary w-100 py-2 fw-bold" style="font-size: 0.85rem;">
                <i class="bi bi-arrow-left me-1"></i> Back to Site
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="admin-main">
        <div class="mb-5 fade-in-up">
            <div class="hero-tag" style="margin-bottom: 1rem;">
                <span class="material-symbols-outlined" style="font-size: 14px;">shield</span>
                Admin Access
            </div>
            <h1 class="fw-bold mb-2" style="font-size: 2.5rem; letter-spacing: -0.02em;">Dashboard Overview</h1>
            <p style="color: var(--sb-text-muted); font-size: 1.05rem;">Platform statistics and pending approvals</p>
        </div>

        <!-- Stat Cards -->
        <div class="row g-3 mb-5 fade-in-up delay-1">
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-glow" style="background: var(--sb-primary);"></div>
                    <div class="stat-card-label">Total Listings</div>
                    <div class="stat-card-value" style="color: var(--sb-text);">@Model.TotalListings</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card" style="border-top-color: rgba(166, 140, 255, 0.3);">
                    <div class="stat-glow" style="background: var(--sb-accent);"></div>
                    <div class="stat-card-label">Pending Review</div>
                    <div class="stat-card-value" style="color: var(--sb-accent-light);">@Model.PendingListingsCount</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card" style="border-top-color: rgba(129, 236, 255, 0.3);">
                    <div class="stat-glow" style="background: var(--sb-primary);"></div>
                    <div class="stat-card-label">Approved</div>
                    <div class="stat-card-value" style="color: var(--sb-primary);">@Model.ApprovedListingsCount</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card" style="border-top-color: rgba(255, 113, 108, 0.3);">
                    <div class="stat-glow" style="background: var(--sb-error);"></div>
                    <div class="stat-card-label">Rejected</div>
                    <div class="stat-card-value" style="color: var(--sb-error);">@Model.RejectedListingsCount</div>
                </div>
            </div>
        </div>

        <!-- Pending Table -->
        <div class="glass-panel overflow-hidden fade-in-up delay-2">
            <div class="p-4 d-flex align-items-center justify-content-between" style="border-bottom: 1px solid rgba(68,72,82,0.15);">
                <div class="d-flex align-items-center gap-3">
                    <h4 class="fw-bold mb-0">Action Required</h4>
                    <span class="status-pill pending">@Model.PendingListings.Count Pending</span>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Item Details</th>
                            <th>Vendor</th>
                            <th>Price / Day</th>
                            <th>AI Risk Score</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.PendingListings.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5" style="color: var(--sb-text-muted);">
                                    <span class="material-symbols-outlined d-block mb-2" style="font-size: 2.5rem; opacity: 0.4;">check_circle</span>
                                    All clear! No listings require review at the moment.
                                </td>
                            </tr>
                        }

                        @foreach (var listing in Model.PendingListings)
                        {
                            var riskColor = listing.RiskScore > 75 ? "var(--sb-error)" : (listing.RiskScore > 40 ? "var(--sb-warning)" : "var(--sb-primary)");
                            var riskLabel = listing.RiskScore > 75 ? "High Risk" : (listing.RiskScore > 40 ? "Medium Risk" : "Low Risk");

                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrEmpty(listing.Item?.ImageUrl))
                                        {
                                            <img src="@listing.Item.ImageUrl" alt="@listing.Item.Name"
                                                 style="width: 48px; height: 48px; border-radius: 10px; object-fit: cover; border: 1px solid var(--sb-outline);" />
                                        }
                                        else
                                        {
                                            <div style="width: 48px; height: 48px; border-radius: 10px; background: var(--sb-surface); display: flex; align-items: center; justify-content: center; color: var(--sb-text-dim);">
                                                <span class="material-symbols-outlined">photo_camera</span>
                                            </div>
                                        }
                                        <div>
                                            <div class="fw-bold">@listing.Item?.Name</div>
                                            <div class="small" style="color: var(--sb-text-dim);">ID: #@listing.Id • @listing.Item?.Condition</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="fw-medium">@listing.Owner?.Name</td>
                                <td class="fw-bold">Rs. @listing.PricePerDay.ToString("N0")</td>
                                <td>
                                    <div style="width: 110px;">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span style="font-size: 0.65rem; font-weight: 700; color: @riskColor;">@riskLabel</span>
                                            <span style="font-size: 0.65rem; font-weight: 700;">@listing.RiskScore/100</span>
                                        </div>
                                        <div class="risk-bar-bg">
                                            <div class="risk-bar-fill" style="width: @(listing.RiskScore)%; background: @riskColor;"></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="status-pill pending">Pending</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex align-items-center justify-content-end gap-1">
                                        @if (listing.Status == "Pending")
                                        {
                                            <form asp-action="Approve" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@listing.Id" />
                                                <button type="submit" class="action-btn action-btn-approve" title="Approve">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            </form>
                                            <form asp-action="Reject" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@listing.Id" />
                                                <button type="submit" class="action-btn action-btn-reject" title="Reject">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        }
                                        <a asp-controller="Listing" asp-action="Details" asp-route-id="@listing.Id"
                                           class="action-btn action-btn-view" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>