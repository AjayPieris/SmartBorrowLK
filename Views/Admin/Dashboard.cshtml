@model SmartBorrowLK.ViewModels.AdminDashboardViewModel
@{ ViewData["Title"] = "Admin Dashboard"; }

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--sb-secondary);">Dashboard Overview</h2>
            <p class="text-muted mb-0">Platform statistics and pending approvals</p>
        </div>
        <div>
            <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">
                <i class="bi bi-shield-lock me-1"></i> Admin Access
            </span>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-title">Total Listings</div>
                <div class="stat-value">@Model.TotalListings</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card border-top border-4 border-warning">
                <div class="stat-title text-warning">Pending Review</div>
                <div class="stat-value text-dark">@Model.PendingListingsCount</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card border-top border-4 border-success">
                <div class="stat-title text-success">Approved</div>
                <div class="stat-value text-dark">@Model.ApprovedListingsCount</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card border-top border-4 border-danger">
                <div class="stat-title text-danger">Rejected</div>
                <div class="stat-value text-dark">@Model.RejectedListingsCount</div>
            </div>
        </div>
    </div>

    <!-- Pending Listings Table -->
    <div class="sb-card border-0 shadow-sm mb-5">
        <div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0">Action Required</h5>
            <span class="badge bg-warning text-dark rounded-pill">@Model.PendingListings.Count Pending</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Item Details</th>
                            <th>Vendor</th>
                            <th>Price / Day</th>
                            <th>AI Risk Score</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.PendingListings.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-check-circle display-4 text-success opacity-25 mb-3 d-block"></i>
                                    All clear! No listings require review at the moment.
                                </td>
                            </tr>
                        }
                        @foreach (var listing in Model.PendingListings)
                        {
                            var riskClass = listing.RiskScore > 75 ? "danger" : (listing.RiskScore > 40 ? "warning" : "success");
                            
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(listing.Item?.ImageUrl))
                                        {
                                            <img src="@listing.Item.ImageUrl" alt="@listing.Item.Name" class="rounded rounded-3 me-3" style="width: 48px; height: 48px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded rounded-3 me-3 d-flex align-items-center justify-content-center text-muted" style="width: 48px; height: 48px;">
                                                <i class="bi bi-camera"></i>
                                            </div>
                                        }
                                        <div>
                                            <div class="fw-semibold text-dark">@listing.Item?.Name</div>
                                            <div class="small text-muted">ID: #@(listing.Id) &bull; @listing.Item?.Condition</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@listing.Owner?.Name</td>
                                <td class="fw-medium">Rs. @listing.PricePerDay.ToString("N0")</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height: 6px; width: 60px;">
                                            <div class="progress-bar bg-@riskClass" role="progressbar" style="width: @listing.RiskScore%" aria-valuenow="@listing.RiskScore" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                        <span class="badge bg-@riskClass-subtle">@listing.RiskScore/100</span>
                                    </div>
                                </td>
                                <td>
                                    @if(listing.Status == "Pending")
                                    {
                                        <span class="badge bg-warning-subtle text-dark"><i class="bi bi-hourglass me-1"></i> Pending</span>
                                    }
                                    else if(listing.Status == "Approved")
                                    {
                                        <span class="badge bg-success-subtle"><i class="bi bi-check me-1"></i> Approved</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle"><i class="bi bi-x me-1"></i> Rejected</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    @if (listing.Status == "Pending")
                                    {
                                        <div class="btn-group">
                                            <form asp-action="Approve" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@listing.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-success">
                                                    <i class="bi bi-check-lg"></i> Approve
                                                </button>
                                            </form>
                                            <form asp-action="Reject" method="post" class="d-inline ms-1">
                                                <input type="hidden" name="id" value="@listing.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-x-lg"></i> Reject
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    <a asp-controller="Listing" asp-action="Details" asp-route-id="@listing.Id" class="btn btn-sm btn-light ms-2">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>