@using SmartBorrowLK.Models
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartBorrow LK</title>
    <meta name="description" content="Rent Smart. Earn Easy. AI-powered tech rental platform in Sri Lanka." />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var userName = Context.Session.GetString("UserName");
        var userRole = Context.Session.GetString("UserRole");
        // We will fake an email since it's not in the session in this app
        var userEmail = userName != null ? $"{userName.Replace(" ","").ToLower()}@example.com" : "";
        var isLoggedIn = !string.IsNullOrEmpty(userName);
        var isAdmin = userRole == "Admin";
        var isVendor = userRole == "Vendor";
        
        string GetInitials(string name) {
            if(string.IsNullOrEmpty(name)) return "U";
            var parts = name.Split(' ');
            if (parts.Length == 1) return parts[0].Substring(0,1).ToUpper();
            return (parts[0].Substring(0,1) + parts[1].Substring(0,1)).ToUpper();
        }
    }

    <nav class="navbar navbar-expand-lg sb-navbar sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <i class="bi bi-box-seam text-primary me-2"></i>
                <span>SmartBorrow <span style="color: var(--sb-accent);">LK</span></span>
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Listing" asp-action="Index">Browse</a>
                    </li>
                    @if (isLoggedIn && isVendor)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Listing" asp-action="MyListings">My Listings</a>
                        </li>
                    }
                    @if (isLoggedIn && isAdmin)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-primary fw-semibold" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a>
                        </li>
                    }
                </ul>
                
                <div class="d-flex align-items-center ms-auto">
                    @if (isLoggedIn)
                    {
                        <a href="#" class="notification-icon" aria-label="Notifications">
                            <i class="bi bi-bell"></i>
                        </a>
                        
                        <div class="dropdown">
                            <button class="profile-btn dropdown-toggle" type="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false" data-bs-offset="0,15">
                                <div class="profile-avatar">
                                    @GetInitials(userName)
                                </div>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-custom" aria-labelledby="profileDropdown">
                                <li class="dropdown-user-info">
                                    <p class="dropdown-user-name">@userName</p>
                                    <p class="dropdown-user-email">@userEmail</p>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                @if (isAdmin)
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard">
                                            <i class="bi bi-speedometer2"></i> Dashboard
                                        </a>
                                    </li>
                                }
                                @if (isVendor)
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Listing" asp-action="MyListings">
                                            <i class="bi bi-collection"></i> My Listings
                                        </a>
                                    </li>
                                }
                                <li>
                                    <a class="dropdown-item" asp-controller="Booking" asp-action="MyBookings">
                                        <i class="bi bi-calendar-check"></i> My Bookings
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="#">
                                        <i class="bi bi-gear"></i> Settings
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item logout-item" asp-controller="Auth" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="nav-link px-3" asp-controller="Auth" asp-action="Login">Log in</a>
                        <a class="btn btn-primary btn-sm ms-2 px-3 py-2 rounded-pill" asp-controller="Auth" asp-action="Register">Sign up</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="container mt-4">
            <div class="alert alert-success alert-dismissible fade show border-0 rounded-3" role="alert" style="background-color: #DCFCE7; color: #166534;">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <main>
        @RenderBody()
    </main>

    <footer>
        <div class="container text-center">
            <p class="mb-2 fw-semibold text-dark">SmartBorrow LK</p>
            <p class="mb-0 small text-muted">&copy; 2026 SmartBorrow LK. All rights reserved.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
