@using SmartBorrowLK.Models
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartBorrow LK</title>
    <meta name="description" content="Rent Smart. Earn Easy. AI-powered tech rental platform in Sri Lanka." />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
          rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
    <script src="https://js.pusher.com/8.2.0/pusher.min.js"></script>
</head>
<body>
    @using Microsoft.Extensions.Configuration
    @inject IConfiguration Configuration
    @{
        var userName = User.Identity?.Name;
        var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
        var userEmail = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value ??
            (userName != null ? $"{userName.Replace(" ", "").ToLower()}@@example.com" : "");
        var userProfileImage = User.Claims.FirstOrDefault(c => c.Type == "ProfileImage")?.Value;
        var isLoggedIn = User.Identity?.IsAuthenticated == true;
        var isAdmin = userRole?.Equals("Admin", StringComparison.OrdinalIgnoreCase) == true;
        var isVendor = userRole?.Equals("Vendor", StringComparison.OrdinalIgnoreCase) == true;

        string GetInitials(string? name)
        {
            if (string.IsNullOrEmpty(name)) return "U";
            var parts = name.Split(' ');
            if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
            return (parts[0].Substring(0, 1) + parts[1].Substring(0, 1)).ToUpper();
        }
    }

    <nav class="navbar navbar-expand-lg sb-navbar sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <i class="bi bi-box-seam me-2" style="color: var(--sb-primary); font-size: 1.3rem;"></i>
                SmartBorrow<span style="color: var(--sb-accent); margin-left: 4px;">LK</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Listing" asp-action="Index">Browse</a>
                    </li>
                    @if (isLoggedIn && isVendor)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Listing" asp-action="Create">List Gear</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Listing" asp-action="MyListings">My Listings</a>
                        </li>
                    }
                    @if (isLoggedIn && isAdmin)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard"
                               style="color: var(--sb-primary); font-weight: 700;">
                                <i class="bi bi-speedometer2 me-1"></i>Admin
                            </a>
                        </li>
                    }
                </ul>

                <div class="d-flex align-items-center gap-2 ms-auto">
                    <button id="themeToggle" class="theme-toggle" aria-label="Toggle Theme">
                        <i class="bi bi-moon-fill"></i>
                    </button>

                    @if (isLoggedIn)
                    {
                        <a href="#" class="notification-icon" aria-label="Notifications">
                            <i class="bi bi-bell"></i>
                        </a>

                        <a href="javascript:void(0)" class="chat-icon ms-2 me-3 position-relative" id="navbarChatBtn" aria-label="Chat">
                            <i class="bi bi-chat-dots fs-5"></i>
                            <span id="globalChatBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">
                                <span id="chatUnreadCount">0</span>
                                <span class="visually-hidden">unread messages</span>
                            </span>
                        </a>

                        <div class="dropdown">
                            <button class="profile-btn dropdown-toggle" type="button" id="profileDropdown"
                                    data-bs-toggle="dropdown" aria-expanded="false" data-bs-offset="0,12">
                                <div class="profile-avatar">
                                    @if (!string.IsNullOrEmpty(userProfileImage))
                                    {
                                        <img src="@userProfileImage" alt="@userName"
                                             style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        @GetInitials(userName)
                                    }
                                </div>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-custom"
                                aria-labelledby="profileDropdown">
                                <li class="dropdown-user-info">
                                    <p class="dropdown-user-name">@userName</p>
                                    <p class="dropdown-user-email">@userEmail</p>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                @if (isAdmin)
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard">
                                            <i class="bi bi-speedometer2"></i> Dashboard
                                        </a>
                                    </li>
                                }
                                @if (isVendor)
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Listing" asp-action="MyListings">
                                            <i class="bi bi-collection"></i> My Listings
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Booking" asp-action="Requests">
                                            <i class="bi bi-inboxes"></i> Booking Requests
                                        </a>
                                    </li>
                                }
                                <li>
                                    <a class="dropdown-item" asp-controller="Booking" asp-action="MyBookings">
                                        <i class="bi bi-calendar-check"></i> My Bookings
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item logout-item" asp-controller="Auth" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="nav-link px-3" asp-controller="Auth" asp-action="Login"
                           style="color: var(--sb-text-muted); font-weight: 600;">Log in</a>
                        <a class="btn btn-primary btn-sm px-3 py-2 rounded-pill" asp-controller="Auth"
                           asp-action="Register">Get Started</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="container mt-4">
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <main>
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
                <div>
                    <div class="footer-brand">SmartBorrow LK</div>
                    <p class="mb-0 small" style="color: var(--sb-text-dim);">&copy; 2026 SmartBorrow LK. All rights reserved.</p>
                </div>
                <div class="d-flex gap-4">
                    <a href="#" style="color: var(--sb-text-dim); font-size: 0.82rem;">Privacy Policy</a>
                    <a href="#" style="color: var(--sb-text-dim); font-size: 0.82rem;">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Global Notification Toast -->
    <div class="toast-container position-fixed bottom-0 start-0 p-3" style="z-index: 1055;">
        <div id="chatToneToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="4000">
            <div class="d-flex">
                <div class="toast-body" style="font-weight: 500; font-size: 0.95rem;">
                    <i class="bi bi-whatsapp me-2"></i> <span id="toastMessageContent">New message received</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <!-- Global Chat Widget -->
    @if (isLoggedIn)
    {
        <div class="chat-widget" id="globalChatWidget">
            <!-- Left Pane: Conversations -->
            <div class="chat-sidebar">
                <div class="chat-sidebar-header">
                    Chats
                    <button class="chat-close-btn d-md-none" id="closeSidebarBtn">&times;</button>
                </div>
                <ul class="chat-sidebar-list" id="chatConversationsList">
                    <li class="p-4 text-center text-muted" style="font-size: 0.9rem;">
                        <div class="spinner-border spinner-border-sm text-primary mb-2" role="status"></div>
                        <div>Loading chats...</div>
                    </li>
                </ul>
            </div>

            <!-- Right Pane: Active Chat -->
            <div class="chat-main" id="chatMainPane">
                
                <!-- Empty State -->
                <div class="chat-body-empty position-relative" id="chatEmptyState">
                    <button class="chat-close-btn position-absolute top-0 end-0 m-3" id="closeEmptyStateBtn">&times;</button>
                    <i class="bi bi-whatsapp" style="font-size: 4rem; color: #d0d0d0;"></i>
                    <h5 class="mt-3 text-muted">SmartBorrow Web</h5>
                    <p class="text-muted" style="font-size: 0.9rem;">Select a user on the left to start chatting.</p>
                </div>

                <!-- Active State (Hidden by default) -->
                <div class="d-flex flex-column h-100 d-none" id="chatActiveState">
                    <div class="chat-header">
                        <div class="chat-header-info">
                            <div class="chat-partner-avatar" id="chatPartnerAvatar">?</div>
                            <div>
                                <h1 class="chat-partner-name" id="chatPartnerName" style="font-size: 1rem; margin-bottom: 2px;">User</h1>
                                <p class="chat-partner-status" style="font-size: 0.75rem; margin-bottom: 0;">Online</p>
                            </div>
                        </div>
                        <div class="chat-header-actions">
                            <i class="bi bi-search"></i>
                            <i class="bi bi-three-dots-vertical"></i>
                            <button class="chat-close-btn p-0 ms-2" id="closeChatBtn" style="font-size: 1.4rem;">&times;</button>
                        </div>
                    </div>
                    
                    <div class="chat-body" id="chatBody"></div>
                    
                    <div class="chat-footer">
                        <div class="footer-actions">
                            <i class="bi bi-emoji-smile"></i>
                            <i class="bi bi-paperclip"></i>
                        </div>
                        <input type="text" class="chat-input" id="chatInputMessage" placeholder="Type a message..." maxlength="500" />
                        <button class="chat-send-btn" id="chatSendBtn">
                            <i class="bi bi-send-fill" style="margin-left: 3px;"></i>
                        </button>
                    </div>
                </div>

            </div>
        </div>

        <script>
            window.chatConfig = {
                pusherKey: '@Configuration["NEXT_PUBLIC_PUSHER_KEY"]',
                pusherCluster: '@Configuration["NEXT_PUBLIC_PUSHER_CLUSTER"]' || 'ap2',
                currentUserId: @(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0")
            };
        </script>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
    @if(isLoggedIn){
       <script src="~/js/chat.js" asp-append-version="true"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
