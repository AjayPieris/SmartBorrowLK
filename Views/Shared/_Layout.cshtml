<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartBorrow LK</title>
    <meta name="description" content="SmartBorrow LK - AI-powered tech rental marketplace for Sri Lanka. Rent cameras, drones, laptops & more." />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var userName = Context.Session.GetString("UserName");
        var userRole = Context.Session.GetString("UserRole");
        var isLoggedIn = !string.IsNullOrEmpty(userName);
        var isAdmin = userRole == "Admin";
        var isVendor = userRole == "Vendor";
    }

    <nav class="navbar navbar-expand-lg navbar-dark sticky-top sb-navbar">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-cpu"></i> SmartBorrow <span class="text-accent">LK</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Listing" asp-action="Index">
                            <i class="bi bi-grid"></i> Browse
                        </a>
                    </li>
                    @if (isLoggedIn && isVendor)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Listing" asp-action="Create">
                                <i class="bi bi-plus-circle"></i> List Item
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Listing" asp-action="MyListings">
                                <i class="bi bi-collection"></i> My Listings
                            </a>
                        </li>
                    }
                    @if (isLoggedIn)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Booking" asp-action="MyBookings">
                                <i class="bi bi-calendar-check"></i> My Bookings
                            </a>
                        </li>
                    }
                    @if (isLoggedIn && isAdmin)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-warning" asp-controller="Admin" asp-action="Dashboard">
                                <i class="bi bi-shield-check"></i> Admin
                            </a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (isLoggedIn)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @userName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark">
                                <li><span class="dropdown-item-text text-muted small">Role: @userRole</span></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Auth" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-accent btn-sm ms-2 mt-1" asp-controller="Auth" asp-action="Register">
                                Get Started
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <main>
        @RenderBody()
    </main>

    <footer class="sb-footer mt-5">
        <div class="container text-center py-4">
            <p class="mb-1">&copy; 2026 SmartBorrow LK — AI-Powered Tech Rentals for Sri Lanka</p>
            <small class="text-muted">Built with ASP.NET Core, Gemini AI & Cloudinary</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
