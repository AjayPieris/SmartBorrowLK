@model SmartBorrowLK.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="auth-wrapper">
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-card fade-in-up">
        <h1>Welcome Back</h1>
        <p class="auth-subtitle">Enter your credentials to access your account.</p>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="font-size: 0.85rem;"></div>

            <!-- Email Field -->
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email Address</label>
                <div class="input-icon-group">
                    <i class="bi bi-envelope input-icon"></i>
                    <input asp-for="Email" class="form-control" placeholder="name@company.com" type="email" />
                </div>
                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Password Field -->
            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center">
                    <label asp-for="Password" class="form-label mb-0">Password</label>
                    <a href="#" style="font-size: 0.75rem; color: var(--sb-accent-light); font-weight: 600;">Forgot Password?</a>
                </div>
                <div class="input-icon-group mt-1">
                    <i class="bi bi-lock input-icon"></i>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" type="password" />
                </div>
                <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Login Button -->
            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold mt-3" style="font-size: 1rem;">
                Login
            </button>
        </form>

        <div class="text-center mt-4">
            <p style="color: var(--sb-text-muted); font-size: 0.9rem;">
                New to SmartBorrowLK?
                <a asp-action="Register" class="fw-bold" style="color: var(--sb-primary);">Create an account</a>
            </p>
        </div>

        <div class="d-flex align-items-center gap-3 mt-4 pt-4" style="border-top: 1px solid var(--sb-outline);">
            <div class="flex-grow-1" style="height: 1px; background: linear-gradient(to right, transparent, var(--sb-outline));"></div>
            <div class="d-flex align-items-center gap-2" style="opacity: 0.5; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--sb-text-dim);">
                <i class="bi bi-shield-check"></i>
                <span>Secure Protocol</span>
            </div>
            <div class="flex-grow-1" style="height: 1px; background: linear-gradient(to left, transparent, var(--sb-outline));"></div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}