@model SmartBorrowLK.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-wrapper">
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-card fade-in-up" style="max-width: 500px;">
        <h1>Create Account</h1>
        <p class="auth-subtitle">Join the SmartBorrowLK community today.</p>

        <form asp-action="Register" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="font-size: 0.85rem;"></div>

            <!-- Name Field -->
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Full Name</label>
                <div class="input-icon-group">
                    <i class="bi bi-person input-icon"></i>
                    <input asp-for="Name" class="form-control" placeholder="John Doe" type="text" />
                </div>
                <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Email Field -->
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email Address</label>
                <div class="input-icon-group">
                    <i class="bi bi-envelope input-icon"></i>
                    <input asp-for="Email" class="form-control" placeholder="name@company.com" type="email" />
                </div>
                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Password Field -->
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <div class="input-icon-group">
                    <i class="bi bi-lock input-icon"></i>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" type="password" />
                </div>
                <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Confirm Password Field -->
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <div class="input-icon-group">
                    <i class="bi bi-lock input-icon"></i>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" type="password" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Profile Image Field -->
            <div class="mb-4">
                <label asp-for="ProfileImage" class="form-label">Profile Image (Optional)</label>
                <input asp-for="ProfileImage" class="form-control" type="file" accept="image/*" />
                <span asp-validation-for="ProfileImage" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Register Button -->
            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold" style="font-size: 1rem;">
                Create Account
            </button>
        </form>

        <div class="text-center mt-4">
            <p style="color: var(--sb-text-muted); font-size: 0.9rem;">
                Already have an account?
                <a asp-action="Login" class="fw-bold" style="color: var(--sb-primary);">Login here</a>
            </p>
        </div>

        <div class="d-flex align-items-center gap-3 mt-4 pt-4" style="border-top: 1px solid var(--sb-outline);">
            <div class="flex-grow-1" style="height: 1px; background: linear-gradient(to right, transparent, var(--sb-outline));"></div>
            <div class="d-flex align-items-center gap-2" style="opacity: 0.5; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--sb-text-dim);">
                <i class="bi bi-shield-check"></i>
                <span>Secure Protocol</span>
            </div>
            <div class="flex-grow-1" style="height: 1px; background: linear-gradient(to left, transparent, var(--sb-outline));"></div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}