<body class="bg-background text-on-surface font-body selection:bg-primary/30 min-h-[884px] flex flex-col" data-mode="connect" data-stitch-vh="min-h-[884px]===min-h-screen">
<!-- TopNavBar (Shared Component) -->
<nav class="fixed top-0 w-full z-50 bg-surface/40 backdrop-blur-xl dark:bg-[#0a0e17]/40 shadow-[0_12px_40px_rgba(235,237,251,0.06)]">
<div class="flex justify-between items-center px-8 py-4 max-w-7xl mx-auto">
<div class="text-2xl font-bold tracking-tighter text-[#81ecff] font-headline">
                SmartBorrowLK
            </div>
<button class="relative flex items-center gap-2 p-1 rounded-full bg-surface-container-lowest/50 border border-primary/20 backdrop-blur-sm shadow-lg shadow-primary/5 hover:shadow-primary/20 transition-all hover:scale-105 active:scale-95 group" id="theme-toggle">
<div class="flex items-center justify-center w-8 h-8 rounded-full bg-primary text-on-primary-container shadow-[0_0_15px_rgba(129,236,255,0.4)] transition-all dark:bg-transparent dark:text-outline-variant dark:shadow-none">
<span class="material-symbols-outlined text-[20px]">light_mode</span>
</div>
<div class="flex items-center justify-center w-8 h-8 rounded-full bg-transparent text-outline-variant transition-all dark:bg-primary dark:text-on-primary-container dark:shadow-[0_0_15px_rgba(129,236,255,0.4)]">
<span class="material-symbols-outlined text-[20px]">dark_mode</span>
</div>
</button>
</div>
</nav>
<!-- Main Canvas -->
<main class="flex-grow flex items-stretch pt-20 overflow-hidden">
<!-- Two Column Layout Container -->
<div class="flex w-full max-w-[1920px] mx-auto">
<!-- Left Side: Kinetic Ether Image -->
<div class="hidden lg:flex lg:w-1/2 relative overflow-hidden">
<img alt="SmartBorrowLK Professional Gear" class="absolute inset-0 w-full h-full object-cover opacity-60" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBuEEqTw4V-ZecdUfGecSRUqHP_Jw8ZyNwDilxpfbPDkcCY6hAlFcuRZo9SXkr5TK_6CLdWIWFaKN5TG5E2bIpHRqxuoyjDHO8sW_Z0xw2pZBHSNGFVKRQmtLJ1cizLkMTKstfZ0ul0cYBB3cuFMORWJRKBBvdm9EuymouunXNTztwfzGpahj9_GpWKRaVKVhGkZESDnZdpO_C2HWL39zYnKzdT21uaz3cn8zjFoVsYDp65H4QjneIBnFZftuxU2GXLYp4KMZAayLo"/>
<div class="absolute inset-0 bg-gradient-to-r from-background/40 to-background/90"></div>
<div class="relative z-10 flex flex-col justify-center px-20 space-y-6">
<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 w-fit">
<span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
<span class="text-[10px] font-bold uppercase tracking-widest text-primary">Live Ether Node</span>
</div>
<h2 class="text-6xl font-headline font-extrabold tracking-tight leading-none text-white">Rent smart. <br/><span class="text-primary">Earn easy.</span></h2>
<p class="text-on-surface-variant text-lg max-w-md font-body leading-relaxed">SmartBorrow LK connects you with trusted users to rent tech equipment, powered by AI for pricing, safety, and convenience.</p>
</div>
<!-- Decorative overlay for seamless transition -->
<div class="absolute top-0 right-0 bottom-0 w-32 ether-image-overlay"></div>
</div>
<!-- Right Side: Login Form -->
<div class="w-full lg:w-1/2 flex items-center justify-center relative p-6 md:p-12">
<!-- 3D Kinetic Background Elements (Restricted to right side or behind form) -->
<div class="absolute inset-0 pointer-events-none z-0">
<div class="absolute top-1/4 -right-20 w-96 h-96 rounded-full ether-glow bg-primary floating-shape"></div>
<div class="absolute bottom-1/4 -left-20 w-[500px] h-[500px] rounded-full ether-glow bg-tertiary floating-shape" style="animation-delay: -5s;"></div>
</div>
<!-- Login Container -->
<div class="relative z-10 w-full max-w-md">
<!-- Glassmorphism Card -->
<div class="glass-panel border-t border-primary/10 rounded-3xl p-8 md:p-12 shadow-[0_40px_80px_rgba(0,0,0,0.5)]">
<div class="mb-10 text-center">
<h1 class="font-headline text-4xl font-extrabold tracking-tight mb-2">Create Account</h1>
<p class="text-on-surface-variant text-sm tracking-wide font-body">Join the SmartBorrowLK community.</p>
</div>
<form asp-action="Register" method="post" enctype="multipart/form-data" class="space-y-6">
<div asp-validation-summary="ModelOnly" class="text-error mb-4 font-body text-sm font-bold"></div>

<!-- Name Field -->
<div class="space-y-2">
<label asp-for="Name" class="block text-xs font-label font-bold uppercase tracking-widest text-on-surface-variant ml-1">Full Name</label>
<div class="relative group">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline-variant group-focus-within:text-primary transition-colors">person</span>
<input asp-for="Name" class="w-full bg-surface-container-lowest border-none outline outline-1 outline-outline-variant/20 rounded-xl py-4 pl-12 pr-4 text-on-surface placeholder:text-on-surface-variant/40 focus:outline-primary/50 focus:ring-0 transition-all font-body" placeholder="John Doe" type="text"/>
</div>
<span asp-validation-for="Name" class="text-error text-xs ml-1 mt-1 block"></span>
</div>


<!-- Email Field -->
<div class="space-y-2">
<label asp-for="Email" class="block text-xs font-label font-bold uppercase tracking-widest text-on-surface-variant ml-1">Email Address</label>
<div class="relative group">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline-variant group-focus-within:text-primary transition-colors">mail</span>
<input asp-for="Email" class="w-full bg-surface-container-lowest border-none outline outline-1 outline-outline-variant/20 rounded-xl py-4 pl-12 pr-4 text-on-surface placeholder:text-on-surface-variant/40 focus:outline-primary/50 focus:ring-0 transition-all font-body" placeholder="name@company.com" type="email"/>
</div>
<span asp-validation-for="Email" class="text-error text-xs ml-1 mt-1 block"></span>
</div>


<!-- Password Field -->
<div class="space-y-2">
<label asp-for="Password" class="block text-xs font-label font-bold uppercase tracking-widest text-on-surface-variant ml-1">Password</label>
<div class="relative group">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline-variant group-focus-within:text-primary transition-colors">lock</span>
<input asp-for="Password" class="w-full bg-surface-container-lowest border-none outline outline-1 outline-outline-variant/20 rounded-xl py-4 pl-12 pr-4 text-on-surface placeholder:text-on-surface-variant/40 focus:outline-primary/50 focus:ring-0 transition-all font-body" placeholder="••••••••" type="password"/>
<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-outline-variant cursor-pointer hover:text-on-surface">visibility</span>
</div>
<span asp-validation-for="Password" class="text-error text-xs ml-1 mt-1 block"></span>
</div>


<!-- Confirm Password Field -->
<div class="space-y-2">
<label asp-for="ConfirmPassword" class="block text-xs font-label font-bold uppercase tracking-widest text-on-surface-variant ml-1">Confirm Password</label>
<div class="relative group">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline-variant group-focus-within:text-primary transition-colors">lock</span>
<input asp-for="ConfirmPassword" class="w-full bg-surface-container-lowest border-none outline outline-1 outline-outline-variant/20 rounded-xl py-4 pl-12 pr-4 text-on-surface placeholder:text-on-surface-variant/40 focus:outline-primary/50 focus:ring-0 transition-all font-body" placeholder="••••••••" type="password"/>
<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-outline-variant cursor-pointer hover:text-on-surface">visibility</span>
</div>
<span asp-validation-for="ConfirmPassword" class="text-error text-xs ml-1 mt-1 block"></span>
</div>


<!-- Profile Image Field -->
<div class="space-y-2">
<label asp-for="ProfileImage" class="block text-xs font-label font-bold uppercase tracking-widest text-on-surface-variant ml-1">Profile Image</label>
<div class="relative group">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline-variant group-focus-within:text-primary transition-colors">image</span>
<input asp-for="ProfileImage" class="w-full bg-surface-container-lowest border-none outline outline-1 outline-outline-variant/20 rounded-xl py-4 pl-12 pr-4 text-on-surface transition-all font-body file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/20 file:text-primary hover:file:bg-primary/30 file:cursor-pointer" type="file" accept="image/*"/>
</div>
<span asp-validation-for="ProfileImage" class="text-error text-xs ml-1 mt-1 block"></span>
</div>


<!-- Register Button -->
<button class="w-full bg-gradient-to-r from-primary to-primary-dim text-on-primary-container font-headline font-extrabold py-4 rounded-xl shadow-lg shadow-primary/10 hover:shadow-primary/30 transition-all hover:scale-[1.02] active:scale-95" type="submit">
                            Register
                        </button>

</form>
<div class="mt-8 text-center">
<p class="text-on-surface-variant text-sm font-body">
                            Already have an account? 
                            <a class="text-primary font-bold hover:underline underline-offset-4 transition-all" asp-action="Login">Login here</a>
</p>
</div>
<!-- Trusted Badge (High Tech Detail) -->
<div class="mt-10 pt-8 border-t border-outline-variant/10 flex justify-center items-center gap-4">
<div class="h-px flex-1 bg-gradient-to-r from-transparent to-outline-variant/20"></div>
<div class="flex items-center gap-2 opacity-40 grayscale group hover:grayscale-0 hover:opacity-100 transition-all">
<span class="material-symbols-outlined text-sm">verified_user</span>
<span class="text-[10px] uppercase tracking-widest font-label font-bold">Secure Protocol v2.4</span>
</div>
<div class="h-px flex-1 bg-gradient-to-l from-transparent to-outline-variant/20"></div>
</div>
</div>
</div>
</div>
</div>
</main>
<!-- Footer (Shared Component) -->
<footer class="w-full py-12 border-t border-[#444852]/20 bg-[#0a0e17] dark:bg-[#0a0e17]">
<div class="flex justify-center items-center px-8 max-w-7xl mx-auto font-headline font-medium text-xs uppercase tracking-widest">
<div class="text-[#a7abb7] opacity-80 hover:opacity-100 transition-opacity font-body">
                © 2026 SmartBorrowLK. Kinetic Ether Systems.
            </div>
</div>
</footer>
</body></html>