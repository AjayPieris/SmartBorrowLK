@model IEnumerable<SmartBorrowLK.Models.Booking>
@{
    ViewData["Title"] = "My Bookings";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-4 gap-3">
        <div>
            <h2 class="mb-1">My Bookings</h2>
            <p class="text-muted mb-0">Track your current and past rentals</p>
        </div>
        <a asp-controller="Listing" asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-search me-1"></i> Find Gear
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-calendar-x display-4 mb-3"></i>
            <h4>No bookings yet</h4>
            <p>You haven't rented any items. Head to the marketplace to find gear!</p>
            <a asp-controller="Listing" asp-action="Index" class="btn btn-primary mt-2">Explore Marketplace</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Item Reserved</th>
                            <th>Rental Dates</th>
                            <th>Duration</th>
                            <th>Total Cost</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model)
                        {
                            var days = (booking.EndDate - booking.StartDate).Days + 1;
                            var totalCost = days * booking.Listing.PricePerDay;
                            var isPast = booking.EndDate < DateTime.UtcNow.Date;

                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(booking.Listing.Item?.ImageUrl))
                                        {
                                            <img src="@booking.Listing.Item.ImageUrl" alt="@booking.Listing.Item.Name"
                                                 class="me-3 rounded object-fit-cover border" style="width: 48px; height: 48px;" />
                                        }
                                        else
                                        {
                                            <div class="me-3 d-flex align-items-center justify-content-center bg-light rounded text-muted"
                                                 style="width: 48px; height: 48px;">
                                                <i class="bi bi-camera"></i>
                                            </div>
                                        }
                                        <span class="fw-semibold">@booking.Listing?.Item?.Name</span>
                                    </div>
                                </td>
                                <td>
                                    <div>@booking.StartDate.ToString("MMM dd, yyyy")</div>
                                    <div class="small text-muted">to @booking.EndDate.ToString("MMM dd, yyyy")</div>
                                </td>
                                <td class="text-muted">@days Days</td>
                                <td class="fw-bold">Rs. @totalCost.ToString("N0")</td>
                                <td>
                                    @if (booking.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (booking.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger">Rejected</span>
                                    }
                                    else if (isPast)
                                    {
                                        <span class="badge bg-secondary">Completed</span>
                                    }
                                    else if (booking.StartDate > DateTime.UtcNow.Date)
                                    {
                                        <span class="badge bg-info text-dark">Upcoming</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Active Now</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-controller="Listing" asp-action="Details" asp-route-id="@booking.ListingId"
                                       class="btn btn-light btn-sm me-1">
                                        View
                                    </a>
                                    @if (isPast && booking.Status == "Approved")
                                    {
                                        <a asp-controller="Review" asp-action="Create" asp-route-listingId="@booking.ListingId"
                                           class="btn btn-outline-warning btn-sm">
                                            <i class="bi bi-star-fill me-1"></i> Review
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>