@model IEnumerable<SmartBorrowLK.Models.Booking>
@{ ViewData["Title"] = "My Bookings"; }

<div class="container py-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-calendar-check"></i> My Rentals</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No bookings yet</h4>
            <p class="text-muted">Head to the <a asp-controller="Listing" asp-action="Index">Marketplace</a> to find gear!</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Dates</th>
                        <th>Duration</th>
                        <th>Total Cost</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model)
                    {
                        var days = (booking.EndDate - booking.StartDate).Days;
                        var totalCost = days * booking.Listing.PricePerDay;
                        var isPast = booking.EndDate < DateTime.UtcNow;

                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="@booking.Listing.Item.ImageUrl" alt="@booking.Listing.Item.Name"
                                         style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px; margin-right: 12px;" />
                                    <strong>@booking.Listing.Item.Name</strong>
                                </div>
                            </td>
                            <td>
                                @booking.StartDate.ToString("MMM dd, yyyy") —<br />
                                @booking.EndDate.ToString("MMM dd, yyyy")
                            </td>
                            <td>@days Days</td>
                            <td class="fw-semibold">Rs. @totalCost.ToString("N0")</td>
                            <td>
                                @if (isPast)
                                {
                                    <span class="badge bg-secondary">Completed</span>
                                }
                                else if (booking.StartDate > DateTime.UtcNow)
                                {
                                    <span class="badge bg-primary">Upcoming</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active Now</span>
                                }
                            </td>
                            <td>
                                @if (isPast)
                                {
                                    <a asp-controller="Review" asp-action="Create" asp-route-listingId="@booking.ListingId"
                                       class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-star"></i> Review
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>