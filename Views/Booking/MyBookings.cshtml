@model IEnumerable<SmartBorrowLK.Models.Booking>
@{ ViewData["Title"] = "My Bookings"; }

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--sb-secondary);">My Bookings</h2>
            <p class="text-muted mb-0">Track your current and past rentals</p>
        </div>
        <div>
            <a asp-controller="Listing" asp-action="Index" class="btn btn-outline-primary rounded-pill px-4">
                <i class="bi bi-search me-1"></i> Find Gear
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-calendar-x display-1 text-muted opacity-50 mb-3"></i>
            <h4 class="fw-semibold" style="color: var(--sb-secondary);">No bookings yet</h4>
            <p class="text-muted mb-4">You haven't rented any items. Head to the marketplace to find gear!</p>
            <a asp-controller="Listing" asp-action="Index" class="btn btn-primary rounded-pill px-4">Explore Marketplace</a>
        </div>
    }
    else
    {
        <div class="sb-card border-0 shadow-sm overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">Item Reserved</th>
                            <th class="py-3">Rental Dates</th>
                            <th class="py-3">Duration</th>
                            <th class="py-3">Total Cost</th>
                            <th class="py-3">Status</th>
                            <th class="text-end pe-4 py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model)
                        {
                            var days = (booking.EndDate - booking.StartDate).Days + 1; // +1 to include both start and end dates
                            var totalCost = days * booking.Listing.PricePerDay;
                            var isPast = booking.EndDate < DateTime.UtcNow.Date;

                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(booking.Listing.Item?.ImageUrl))
                                        {
                                            <img src="@booking.Listing.Item.ImageUrl" alt="@booking.Listing.Item.Name"
                                                 class="rounded-3 me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded-3 me-3 d-flex align-items-center justify-content-center text-muted" style="width: 50px; height: 50px;">
                                                <i class="bi bi-camera"></i>
                                            </div>
                                        }
                                        <div class="fw-semibold text-dark">@booking.Listing?.Item?.Name</div>
                                    </div>
                                </td>
                                <td class="py-3 text-muted small">
                                    <div class="fw-medium text-dark">@booking.StartDate.ToString("MMM dd, yyyy")</div>
                                    <div>to @booking.EndDate.ToString("MMM dd, yyyy")</div>
                                </td>
                                <td class="py-3 text-muted">@days Days</td>
                                <td class="py-3 fw-semibold text-accent">Rs. @totalCost.ToString("N0")</td>
                                <td class="py-3">
                                    @if (isPast)
                                    {
                                        <span class="badge bg-secondary-subtle">Completed</span>
                                    }
                                    else if (booking.StartDate > DateTime.UtcNow.Date)
                                    {
                                        <span class="badge bg-primary-subtle">Upcoming</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle">Active Now</span>
                                    }
                                </td>
                                <td class="text-end pe-4 py-3">
                                    <a asp-controller="Listing" asp-action="Details" asp-route-id="@booking.ListingId" class="btn btn-sm btn-light rounded-pill px-3 me-2">
                                        View
                                    </a>
                                    @if (isPast)
                                    {
                                        <a asp-controller="Review" asp-action="Create" asp-route-listingId="@booking.ListingId"
                                           class="btn btn-sm btn-outline-warning rounded-pill px-3">
                                            <i class="bi bi-star-fill me-1"></i> Review
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>