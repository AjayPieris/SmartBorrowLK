@model SmartBorrowLK.ViewModels.CreateBookingViewModel
@{ ViewData["Title"] = "Confirm Booking"; }

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <a asp-controller="Listing" asp-action="Details" asp-route-id="@Model.ListingId"
               class="btn btn-outline-secondary btn-sm mb-4">
                &larr; Back to Listing
            </a>

            <h2 class="mb-4">Confirm Your Booking</h2>

            <div class="card shadow-sm mb-4">
                <div class="row g-0">
                    <div class="col-md-4 bg-light border-end d-flex align-items-center justify-content-center p-4">
                        <div class="text-center">
                            <i class="bi bi-calendar-check text-primary mb-2" style="font-size: 2.5rem;"></i>
                            <h5 class="fw-bold mb-1">@Model.ItemName</h5>
                            <p class="text-muted mb-0">Rs. @Model.PricePerDay.ToString("N0") / day</p>
                        </div>
                    </div>
                    <div class="col-md-8 p-4">
                        <form asp-action="Book" method="post">
                            <input type="hidden" asp-for="ListingId" />
                            <input type="hidden" asp-for="PricePerDay" />
                            <input type="hidden" asp-for="ItemName" />

                            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                            <div class="row mb-3">
                                <div class="col-sm-6 mb-3 mb-sm-0">
                                    <label asp-for="StartDate" class="form-label">Start Date</label>
                                    <input asp-for="StartDate" type="date" class="form-control" id="startDate"
                                           required min="@DateTime.UtcNow.ToString("yyyy-MM-dd")" />
                                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label asp-for="EndDate" class="form-label">End Date</label>
                                    <input asp-for="EndDate" type="date" class="form-control" id="endDate"
                                           required min="@DateTime.UtcNow.ToString("yyyy-MM-dd")" />
                                    <span asp-validation-for="EndDate" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center bg-light p-3 rounded mb-4 border">
                                <span class="fw-semibold text-muted">Estimated Total:</span>
                                <span class="fw-bold fs-4" id="totalCost">--</span>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">
                                Request Booking
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <p class="text-center text-muted small">
                <i class="bi bi-shield-check text-success me-1"></i>
                Secure booking. You won't be charged until the owner approves.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const pricePerDay = @Model.PricePerDay;
        const startDate = document.getElementById('startDate');
        const endDate = document.getElementById('endDate');
        const totalCost = document.getElementById('totalCost');

        function updateTotal() {
            if (!startDate.value || !endDate.value) {
                totalCost.innerText = '--';
                return;
            }

            const start = new Date(startDate.value);
            const end = new Date(endDate.value);

            if (end < start) {
                totalCost.innerText = '--';
                return;
            }

            const timeDiff = end.getTime() - start.getTime();
            const days = Math.floor(timeDiff / (1000 * 3600 * 24)) + 1;
            
            const total = days * pricePerDay;
            totalCost.innerText = 'Rs. ' + total.toLocaleString();
        }

        startDate.addEventListener('change', function(e) {
            endDate.min = e.target.value;
            
            if (endDate.value && new Date(endDate.value) < new Date(e.target.value)) {
                endDate.value = e.target.value;
            }
            
            updateTotal();
        });

        endDate.addEventListener('change', updateTotal);
    </script>
}