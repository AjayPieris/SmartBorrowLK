@model IEnumerable<SmartBorrowLK.Models.Booking>
@{
    ViewData["Title"] = "Booking Requests";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--sb-secondary);">Booking Requests</h2>
            <p class="text-muted mb-0">Manage incoming booking requests for your listings</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox display-1 text-muted opacity-50 mb-3"></i>
            <h4 class="fw-semibold" style="color: var(--sb-secondary);">No requests yet</h4>
            <p class="text-muted mb-4">You have not received any booking requests yet.</p>
            <a asp-controller="Listing" asp-action="Create" class="btn btn-primary rounded-pill px-4">Create More
                Listings</a>
            </div>
        }
    else
        {
            <div class="row g-4">
                @foreach (var booking in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="sb-card h-100 flex-column">
                            <div class="position-relative">
                                @if (!string.IsNullOrEmpty(booking.Listing.ImageUrl))
                                {
                                    <img src="@booking.Listing.ImageUrl" class="card-img-top" alt="@booking.Listing.Item.Name"
                                         style="height: 200px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center"
                                         style="height: 200px; border-top-left-radius: var(--sb-radius); border-top-right-radius: var(--sb-radius);">
                                        <i class="bi bi-device-hdd text-secondary" style="font-size: 3rem; opacity: 0.5;"></i>
                                    </div>
                                }
                                <span
                                    class="badge position-absolute top-0 end-0 m-3 shadow-sm @(booking.Status == "Approved" ? "bg-success" : booking.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark")">
                                    @booking.Status
                                </span>
                            </div>
                            <div class="card-body p-4 flex-grow-1 d-flex flex-column">
                                <h5 class="fw-bold mb-1">@booking.Listing.Item.Name</h5>
                            
                                <div class="my-3 flex-grow-1">
                                    <div class="d-flex align-items-center mb-2">
                                        <i class="bi bi-person me-2 text-primary"></i>
                                        <span class="text-muted small">Requester: <span
                                            class="fw-semibold text-dark">@booking.User.Name</span></span>
                                        </div>
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="bi bi-calendar-event me-2 text-primary"></i>
                                            <span class="text-muted small">Dates: <span
                                                class="fw-semibold text-dark">@booking.StartDate.ToShortDateString() -
                                                @booking.EndDate.ToShortDateString()</span></span>
                                            </div>
                                            <div class="d-flex align-items-center">
                                                <i class="bi bi-cash me-2 text-primary"></i>
                                                <span class="text-muted small">Total: <span class="fw-semibold text-dark">LKR
                                                    @(booking.Listing.PricePerDay * (int)Math.Max(1, (booking.EndDate -
                                                    booking.StartDate).TotalDays))</span></span>
                                                </div>
                                            </div>
                            
                                            @if (booking.Status == "Pending")
                                            {
                                                <div class="d-flex gap-2 mt-auto pt-3 border-top border-light">
                                                    <form asp-action="UpdateStatus" method="post" class="flex-grow-1">
                                                        <input type="hidden" name="id" value="@booking.Id" />
                                                        <input type="hidden" name="status" value="Approved" />
                                                        <button type="submit" class="btn btn-success w-100 py-2" style="font-weight: 500;">
                                                            <i class="bi bi-check-circle me-1"></i> Approve
                                                        </button>
                                                    </form>
                                                    <form asp-action="UpdateStatus" method="post" class="flex-grow-1">
                                                        <input type="hidden" name="id" value="@booking.Id" />
                                                        <input type="hidden" name="status" value="Rejected" />
                                                        <button type="submit" class="btn btn-outline-danger w-100 py-2" style="font-weight: 500;">
                                                            <i class="bi bi-x-circle me-1"></i> Reject
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>