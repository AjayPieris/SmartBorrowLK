@model IEnumerable<SmartBorrowLK.Models.Booking>
@{
    ViewData["Title"] = "Booking Requests";
}

<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-end mb-5 gap-3 fade-in-up">
        <div>
            <h2 class="fw-bold mb-1" style="font-size: 2rem;">Booking Requests</h2>
            <p style="color: var(--sb-text-muted); margin-bottom: 0;">Manage incoming booking requests for your listings</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state fade-in-up">
            <i class="bi bi-inbox"></i>
            <h4 class="fw-bold mt-3 mb-2">No requests yet</h4>
            <p style="color: var(--sb-text-muted);">You have not received any booking requests yet.</p>
            <a asp-controller="Listing" asp-action="Create" class="btn btn-primary rounded-pill px-4 mt-2">Create More Listings</a>
        </div>
    }
    else
    {
        <div class="row g-4 fade-in-up delay-1">
            @foreach (var booking in Model)
            {
                var days = (booking.EndDate - booking.StartDate).Days + 1;
                <div class="col-md-6 col-lg-4">
                    <div class="glass-panel h-100 d-flex flex-column overflow-hidden">
                        <div class="position-relative">
                            @if (!string.IsNullOrEmpty(booking.Listing.ImageUrl))
                            {
                                <img src="@booking.Listing.ImageUrl" alt="@booking.Listing.Item.Name"
                                     style="width: 100%; height: 200px; object-fit: cover;" />
                            }
                            else if (!string.IsNullOrEmpty(booking.Listing.Item?.ImageUrl))
                            {
                                <img src="@booking.Listing.Item.ImageUrl" alt="@booking.Listing.Item.Name"
                                     style="width: 100%; height: 200px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center"
                                     style="height: 200px; background: var(--sb-surface); color: var(--sb-text-dim); font-size: 2.5rem;">
                                    <i class="bi bi-device-hdd"></i>
                                </div>
                            }
                            @if (booking.Status == "Approved")
                            {
                                <span class="position-absolute top-0 end-0 m-3 status-pill approved">Approved</span>
                            }
                            else if (booking.Status == "Rejected")
                            {
                                <span class="position-absolute top-0 end-0 m-3 status-pill rejected">Rejected</span>
                            }
                            else
                            {
                                <span class="position-absolute top-0 end-0 m-3 status-pill pending">Pending</span>
                            }
                        </div>
                        <div class="p-4 flex-grow-1 d-flex flex-column">
                            <h5 class="fw-bold mb-1">@booking.Listing.Item.Name</h5>

                            <div class="my-3 flex-grow-1">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-person me-2" style="color: var(--sb-primary);"></i>
                                    <span class="small" style="color: var(--sb-text-muted);">Requester:
                                        <span class="fw-semibold" style="color: var(--sb-text);">@booking.User.Name</span>
                                    </span>
                                </div>
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-calendar-event me-2" style="color: var(--sb-primary);"></i>
                                    <span class="small" style="color: var(--sb-text-muted);">Dates:
                                        <span class="fw-semibold" style="color: var(--sb-text);">@booking.StartDate.ToShortDateString() - @booking.EndDate.ToShortDateString()</span>
                                    </span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-cash me-2" style="color: var(--sb-primary);"></i>
                                    <span class="small" style="color: var(--sb-text-muted);">Total:
                                        <span class="fw-semibold text-price">LKR @((booking.Listing.PricePerDay * days).ToString("N0"))</span>
                                    </span>
                                </div>
                            </div>

                            @if (booking.Status == "Pending")
                            {
                                <div class="d-flex gap-2 mt-auto pt-3" style="border-top: 1px solid var(--sb-outline);">
                                    <form asp-action="UpdateStatus" method="post" class="flex-grow-1">
                                        <input type="hidden" name="id" value="@booking.Id" />
                                        <input type="hidden" name="status" value="Approved" />
                                        <button type="submit" class="btn btn-success w-100 py-2 fw-semibold">
                                            <i class="bi bi-check-circle me-1"></i> Approve
                                        </button>
                                    </form>
                                    <form asp-action="UpdateStatus" method="post" class="flex-grow-1">
                                        <input type="hidden" name="id" value="@booking.Id" />
                                        <input type="hidden" name="status" value="Rejected" />
                                        <button type="submit" class="btn btn-outline-danger w-100 py-2 fw-semibold">
                                            <i class="bi bi-x-circle me-1"></i> Reject
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>