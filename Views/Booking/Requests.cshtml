@model IEnumerable<SmartBorrowLK.Models.Booking>
@{
    ViewData["Title"] = "Booking Requests";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="mb-1">Booking Requests</h2>
        <p class="text-muted mb-0">Manage incoming booking requests for your listings</p>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox display-4 mb-3"></i>
            <h4>No requests yet</h4>
            <p>You have not received any booking requests yet.</p>
            <a asp-controller="Listing" asp-action="Create" class="btn btn-primary mt-2">Create More Listings</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var booking in Model)
            {
                var days = (booking.EndDate - booking.StartDate).Days + 1;
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="position-relative">
                            @if (!string.IsNullOrEmpty(booking.Listing.ImageUrl))
                            {
                                <img src="@booking.Listing.ImageUrl" alt="@booking.Listing.Item.Name"
                                     class="card-img-top object-fit-cover" style="height: 200px;" />
                            }
                            else if (!string.IsNullOrEmpty(booking.Listing.Item?.ImageUrl))
                            {
                                <img src="@booking.Listing.Item.ImageUrl" alt="@booking.Listing.Item.Name"
                                     class="card-img-top object-fit-cover" style="height: 200px;" />
                            }
                            else
                            {
                                <div class="card-img-top bg-light d-flex align-items-center justify-content-center text-muted"
                                     style="height: 200px; font-size: 2.5rem;">
                                    <i class="bi bi-device-hdd"></i>
                                </div>
                            }
                            @if (booking.Status == "Approved")
                            {
                                <span class="position-absolute top-0 end-0 m-2 badge bg-success">Approved</span>
                            }
                            else if (booking.Status == "Rejected")
                            {
                                <span class="position-absolute top-0 end-0 m-2 badge bg-danger">Rejected</span>
                            }
                            else
                            {
                                <span class="position-absolute top-0 end-0 m-2 badge bg-warning text-dark">Pending</span>
                            }
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold mb-3">@booking.Listing.Item.Name</h5>

                            <div class="mb-4">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-person text-primary me-2"></i>
                                    <span class="text-muted small">Requester: <strong class="text-dark">@booking.User.Name</strong></span>
                                </div>
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-calendar-event text-primary me-2"></i>
                                    <span class="text-muted small">Dates: <strong class="text-dark">@booking.StartDate.ToShortDateString() - @booking.EndDate.ToShortDateString()</strong></span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-cash text-primary me-2"></i>
                                    <span class="text-muted small">Total: <strong class="text-dark">LKR @((booking.Listing.PricePerDay * days).ToString("N0"))</strong></span>
                                </div>
                            </div>

                            @if (booking.Status == "Pending")
                            {
                                <div class="d-flex gap-2 mt-auto pt-3 border-top">
                                    <form asp-action="UpdateStatus" method="post" class="w-50">
                                        <input type="hidden" name="id" value="@booking.Id" />
                                        <input type="hidden" name="status" value="Approved" />
                                        <button type="submit" class="btn btn-success w-100">
                                            Approve
                                        </button>
                                    </form>
                                    <form asp-action="UpdateStatus" method="post" class="w-50">
                                        <input type="hidden" name="id" value="@booking.Id" />
                                        <input type="hidden" name="status" value="Rejected" />
                                        <button type="submit" class="btn btn-outline-danger w-100">
                                            Reject
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>